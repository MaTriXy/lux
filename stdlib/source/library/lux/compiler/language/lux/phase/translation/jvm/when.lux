(.using
 [library
  [lux (.except Type Label
                let exec when its
                if or and)
   [abstract
    ["[0]" monad]]
   [data
    ["[0]" pair]
    ["[0]" maybe (.open functor)]
    [collection
     ["[0]" list (.open monoid functor)]
     ["[0]" set]]]
   [math
    [number
     ["i[0]" /32
      ["[1]" integer]]
     [/64
      ["n" natural]
      ["i" integer]]]]
   [macro
    ["[0]" template]]
   [target
    [jvm
     ["_" bytecode (.only Label Bytecode) (.open monad)]
     ["[0]" type (.only Type)
      [category (.only Method)]]]]]]
 ["[0]" //
  ["[1][0]" type]
  ["[1][0]" runtime (.only Operation Phase Expression)]
  ["[1][0]" value]
  ["[1][0]" complex]
  ["[1][0]" primitive]
  [////
   ["[0]" phase (.open monad)]
   ["[0]" translation]
   ["[0]" synthesis (.only Term)
    ["[0]" path (.only Path Fork)]
    [access
     ["[0]" member (.only Member)]]]
   [///
    [type (.only Register)]]]])

(the (pop_alt stack_depth)
  (-> Natural
      (Bytecode Any))
  (.when stack_depth
    0 (_:pure [])
    1 _.pop
    2 _.pop2
    _
    (comment (n.> 2)
             (all _.composite
                  _.pop2
                  (pop_alt (n.- 2 stack_depth))))))

(the int
  (-> (I64 Any)
      (Bytecode Any))
  (|>> .integer i/32.of _.int))

(the pop
  (Bytecode Any)
  (all _.composite
       (//runtime.item //runtime.tail_of_stack)
       (_.checkcast //type.stack)))

(the current
  (Bytecode Any)
  (all _.composite
       _.dup
       (//runtime.item //runtime.head_of_stack)))

(the previous
  (Bytecode Any)
  (all _.composite
       _.dup
       ..pop
       (//runtime.item //runtime.head_of_stack)))

(the .public (left_of_tuple lefts)
  (-> Natural
      (Bytecode Any))
  (all _.composite
       (_.checkcast //type.tuple)
       (..int lefts)
       (.when lefts
         0
         _.aaload
         
         lefts
         //runtime.left_of_tuple)))

(the .public (right_of_tuple lefts)
  (-> Natural
      (Bytecode Any))
  (all _.composite
       (_.checkcast //type.tuple)
       (..int lefts)
       //runtime.right_of_tuple))

(the object_equals
  (.let [class (type.class (list) "java.lang.Object")
         method (type.method [(list) (list //type.value) type.boolean (list)])]
    (_.invokevirtual class "equals" method)))

(the (bind register)
  (-> Register
      (Operation (Bytecode Any)))
  (phase:pure (all _.composite
                   ..current
                   (_.astore register))))

(the (bit_pattern_matching of @external_else [when thenP elseP])
  (-> (-> (Path Term) (Operation (Bytecode Any)))
      Label [Bit (Path Term) (Maybe (Path Term))]
      (Operation (Bytecode Any)))
  (monad.let [! phase.monad]
    [then! (of thenP)
     else!,@else (.when elseP
                   {.:Some elseP}
                   (|> (of elseP)
                       (by ! each (function (_ else!)
                                    (monad.let _.monad
                                      [@internal_else _.new_label]
                                      (pure [(all _.composite
                                                  (_.set_label @internal_else)
                                                  else!)
                                             @internal_else])))))

                   {.:None}
                   (pure (_:pure [(_:pure [])
                                  @external_else])))
     .let [if! (.if when _.ifeq _.ifne)]]
    (pure (monad.let _.monad
            [[else! @else] else!,@else]
            (all _.composite
                 ..current
                 (//value.primitive type.boolean)
                 (if! @else)
                 then!
                 else!)))))

(template.with [<name> <type> <unwrap> <dup> <pop> <test> <comparison> <if>]
               [(the (<name> of @external_else [head tail])
                  (-> (-> (Path Term) (Operation (Bytecode Any)))
                      Label (Fork <type> (Path Term))
                      (Operation (Bytecode Any)))
                  (monad.let [! phase.monad]
                    [fork! (.when tail
                             (list)
                             (monad.let !
                               [.let [[test thenP] head]
                                then! (of thenP)]
                               (pure (all _.composite
                                          (<test> test)
                                          <comparison>
                                          (<if> @external_else)
                                          then!)))

                             else
                             (list.mix' ! (function (_ [test thenP] else!)
                                            (monad.let !
                                              [then! (of thenP)]
                                              (pure (monad.let _.monad
                                                      [@internal_else _.new_label]
                                                      (all _.composite
                                                           <dup>
                                                           (<test> test)
                                                           <comparison>
                                                           (<if> @internal_else)
                                                           <pop>
                                                           then!
                                                           (_.set_label @internal_else)
                                                           else!)))))
                                        (list.in_reverse (list:composite (list head) tail))
                                        (all _.composite
                                             <pop>
                                             (_.goto @external_else))))]
                    (pure (all _.composite
                               ..current
                               <unwrap>
                               fork!))))]

               [[i64_pattern_matching I64 (//value.primitive type.long) _.dup2 _.pop2 //primitive.i64' _.lcmp _.ifne]
                [f64_pattern_matching F64 (//value.primitive type.double) _.dup2 _.pop2 //primitive.f64' _.dcmpl _.ifne]
                [text_pattern_matching Text (by _.monad pure []) _.dup _.pop //primitive.text ..object_equals _.ifeq]])

(the (any_list_item index)
  (-> (I64 Any)
      (Bytecode Any))
  (all _.composite
       (_.checkcast //type.list)
       (..int index)
       _.aaload))

(the replace_current!
  (Bytecode Any)
  (all _.composite
       //runtime.head_of_stack
       _.swap
       _.aastore
       ))

(the (binding_of of access register then)
  (-> (-> (Path Term) (Operation (Bytecode Any)))
      (Bytecode Any) Register (Path Term)
      (Operation (Bytecode Any)))
  (monad.let phase.monad
    [then (of then)]
    (pure (all _.composite
               ..current
               access
               (_.astore register)
               then))))

(the (substitution_by of access then)
  (-> (-> (Path Term) (Operation (Bytecode Any)))
      (Bytecode Any) (Path Term)
      (Operation (Bytecode Any)))
  (monad.let phase.monad
    [.let [_ (.log!# "!! substitution_by")]
     then (of then)]
    (pure (all _.composite
               _.dup
               ..previous
               access
               ..replace_current!
               then))))

(the (pattern_matching' stack_depth @else @end expression archive)
  (-> Natural Label Label
      (Expression (Path Term)))
  (function (of path)
    (`` (.when path
          {path.:Pop}
          (phase:pure ..pop)
          
          {path.:Bind register}
          (..bind register)

          (,, (template.with [<tag> <path>]
                             [{<tag> it}
                              (<path> of @else it)]

                             [[path.:Bit_Fork ..bit_pattern_matching]
                              [path.:I64_Fork ..i64_pattern_matching]
                              [path.:F64_Fork ..f64_pattern_matching]
                              [path.:Text_Fork ..text_pattern_matching]]))

          {path.:Then bodyS}
          (monad.let phase.monad
            [body! (expression archive bodyS)]
            (pure (all _.composite
                       (..pop_alt stack_depth)
                       body!
                       (_.when_continuous (_.goto @end)))))
          
          (path.side lefts right?)
          (phase:pure (monad.let _.monad
                        [@success _.new_label]
                        (all _.composite
                             ..current
                             (_.checkcast //type.variant)
                             (//complex.lefts lefts)
                             (//complex.right? right?)
                             //runtime.when
                             _.dup
                             (_.ifnonnull @success)
                             _.pop
                             (_.goto @else)
                             (_.set_label @success)
                             //runtime.stack)))

          (,, (template.with [<pattern> <projection>]
                             [(<pattern> lefts)
                              (phase:pure (all _.composite
                                               ..current
                                               (<projection> lefts)
                                               //runtime.stack))

                              (path.binding_of_member <pattern> lefts register then)
                              (comment (path.substitution_by_member <pattern> lefts then)
                                       (..substitution_by of (<projection> lefts) then)

                                       (..binding_of of (<projection> lefts) register then))]

                             [[path.left_member ..left_of_tuple]
                              [path.right_member ..right_of_tuple]]))

          {path.:List size}
          (phase:pure (all _.composite
                           ..current
                           (_.checkcast //type.list)
                           _.arraylength
                           (..int size)
                           (_.if_icmpne @else)))
          
          (path.item index)
          (phase:pure (all _.composite
                           ..current
                           (..any_list_item index)
                           //runtime.stack))

          (path.binding_of_item index register then)
          (comment (path.substitution_by_item index then)
                   (..substitution_by of (..any_list_item index) then)

                   (..binding_of of (..any_list_item index) register then))

          {path.:Or leftP rightP}
          (monad.let phase.monad
            [@alt_else //runtime.forge_label
             left! (pattern_matching' (++ stack_depth) @alt_else @end expression archive leftP)
             right! (of rightP)]
            (pure (all _.composite
                       _.dup
                       left!
                       (_.set_label @alt_else)
                       _.pop
                       right!)))
          
          {path.:And leftP rightP}
          (monad.let phase.monad
            [left! (of leftP)
             right! (of rightP)]
            (pure (all _.composite
                       left!
                       right!)))
          ))))

(the (pattern_matching @end expression archive path)
  (-> Label
      (Expression (Path Term)))
  (monad.let phase.monad
    [@else //runtime.forge_label
     pattern_matching! (..pattern_matching' 1 @else @end expression archive path)]
    (pure (all _.composite
               pattern_matching!
               (<| (_.when_acknowledged @else)
                   (all _.composite
                        (_.set_label @else)
                        //runtime.pm_failure
                        (_.goto @end)
                        ))
               ))))

(the .public (exec expression archive [this that])
  (Expression synthesis.Exec)
  (monad.let phase.monad
    [this! (expression archive this)
     that! (expression archive that)]
    (pure (all _.composite
               this!
               _.pop
               that!))))

(the .public (let expression archive [register inputS bodyS])
  (Expression synthesis.Let)
  (monad.let phase.monad
    [input! (expression archive inputS)
     body! (expression archive bodyS)]
    (pure (all _.composite
               input!
               (_.astore register)
               body!))))

(the (projection it)
  (.if (.its member.:right? it)
       (..right_of_tuple (.its member.:lefts it))
       (..left_of_tuple (.its member.:lefts it))))

(the .public (its expression archive [path recordS])
  (Expression synthesis.Its)
  (monad.let phase.monad
    [record! (expression archive recordS)]
    (pure (list.mix (function (_ step so_far!)
                      (all _.composite
                           so_far!
                           (..projection step)))
                    path
                    record!))))

(the .public (when expression archive [valueS path])
  (Expression [Term (Path Term)])
  (monad.let phase.monad
    [@end //runtime.forge_label
     value! (expression archive valueS)
     pattern_matching! (..pattern_matching @end expression archive path)]
    (pure (all _.composite
               _.aconst_null
               value!
               //runtime.stack
               pattern_matching!
               (<| (_.when_acknowledged @end)
                   (_.set_label @end))))))

(the .public (multi_let expression archive [input bindings body])
  (Expression synthesis.Multi_Let)
  (monad.let phase.monad
    [input (expression archive input)
     body (expression archive body)]
    (pure (all _.composite
               (list.mix (function (_ [register member] left)
                           (all _.composite
                                left
                                _.dup
                                (..projection member)
                                (_.astore register)))
                         bindings
                         input)
               _.pop
               body))))

(the .public (if expression archive [testS thenS elseS])
  (Expression (synthesis.If Term))
  (monad.let phase.monad
    [test! (expression archive testS)
     then! (expression archive thenS)
     else! (expression archive elseS)]
    (pure (monad.let _.monad
            [@else _.new_label
             @end _.new_label]
            (all _.composite
                 test!
                 (//value.primitive type.boolean)
                 (_.ifeq @else)
                 then!
                 (_.when_continuous (_.goto @end))
                 (_.set_label @else)
                 else!
                 (<| (_.when_acknowledged @end)
                     (_.set_label @end)))))))

(the variant:lefts
  (all _.composite
       _.iconst_0
       _.aaload
       (//value.primitive type.int)
       ))

(the variant:right?
  (all _.composite
       _.iconst_1
       _.aaload
       ))

(the variant:when_left
  (all _.composite
       _.iconst_2
       _.aaload
       ))

(the variant:when_right
  (all _.composite
       (//complex.lefts 0)
       (//complex.right? true)
       //runtime.when
       ))

(the (bind_left! the_left)
  (all _.composite
       variant:when_left
       (_.astore the_left)))

(the (bind_right! the_right)
  (all _.composite
       variant:when_right
       (_.astore the_right)))

(the .public (variant_if expression archive [test [the_left left] [the_right right]])
  (Expression (synthesis.If [(Maybe Register) Term]))
  (monad.let phase.monad
    [test (expression archive test)
     left (expression archive left)
     right (expression archive right)]
    (pure (monad.let _.monad
            [@right _.new_label
             @end _.new_label
             .let [not_binding! _.pop
                   with_left (|> the_left
                                 (maybe:each bind_left!)
                                 (maybe.else not_binding!))
                   with_right (|> the_right
                                  (maybe:each bind_right!)
                                  (maybe.else not_binding!))]]
            (all _.composite
                 test (_.checkcast //type.variant)
                 _.dup variant:right? (_.ifnonnull @right)
                 _.dup variant:lefts (_.ifne @right)

                 with_left
                 left
                 (_.when_continuous (_.goto @end))
                 
                 (_.set_label @right)
                 with_right
                 right
                 (<| (_.when_acknowledged @end)
                     (_.set_label @end)))))))

(template.with [,exposure ,name ,type ,un_box ,literal ,dup ,pop ,comparison ,if]
               [(the ,exposure (,name expression archive [input cases else])
                  (Expression [Term (List [,type Term]) Term])
                  (monad.let [! phase.monad]
                    [input (expression archive input)
                     cases (list.each' ! (function (_ [when then])
                                           (by ! each
                                               (|>> [when])
                                               (expression archive then)))
                                       cases)
                     else (expression archive else)]
                    (pure (monad.let [! _.monad]
                            [@end _.new_label]
                            (all _.composite
                                 input
                                 ,un_box
                                 (list.mix (function (_ [when then] else)
                                             (monad.let [! _.monad]
                                               [@else _.new_label]
                                               (all _.composite
                                                    ,dup
                                                    (,literal when)
                                                    ,comparison
                                                    (,if @else)
                                                    ,pop
                                                    then
                                                    (_.when_continuous (_.goto @end))
                                                    (_.set_label @else)
                                                    else)))
                                           (list.in_reverse cases)
                                           (all _.composite
                                                ,pop
                                                else
                                                (<| (_.when_acknowledged @end)
                                                    (_.set_label @end)))))))))]

               [[.private when_i64|general I64 (//value.primitive type.long) //primitive.i64' _.dup2 _.pop2 _.lcmp _.ifne]
                [.public when_f64 F64 (//value.primitive type.double) //primitive.f64' _.dup2 _.pop2 _.dcmpl _.ifne]
                [.public when_text Text (pure []) //primitive.text _.dup _.pop ..object_equals _.ifeq]])

(the (when_i64|table expression archive [input minimum every_case else])
  (Expression [Term i/32.Number (List Term) Term])
  (monad.let [! phase.monad]
    [input (expression archive input)
     every_case (list.each' ! (expression archive) every_case)
     else (expression archive else)
     .let [head (.list_item# 0 every_case)
           tail (list.after 1 every_case)]]
    (pure (monad.let [! _.monad]
            [@head _.new_label
             tail (list.each' ! (function (_ then)
                                  (monad.let !
                                    [@then _.new_label]
                                    (pure [@then then])))
                              tail)
             
             @pre_else _.new_label
             @else _.new_label
             @end _.new_label]
            (all _.composite
                 input (//value.primitive type.long)
                 _.dup2 (_.long (i/32.as i/32.maximum)) _.lcmp (_.ifgt @pre_else)
                 _.dup2 (_.long (i/32.as i/32.minimum)) _.lcmp (_.iflt @pre_else)
                 _.l2i (_.tableswitch minimum @else [@head (list:each pair.left tail)])
                 (list.mix (function (_ [@then then] else)
                             (all _.composite
                                  (_.set_label @then)
                                  then
                                  (_.when_continuous (_.goto @end))
                                  else))
                           (list.in_reverse (list:composite (list [@head head]) tail))
                           (all _.composite
                                (_.set_label @pre_else)
                                _.pop2
                                (_.set_label @else)
                                else
                                (<| (_.when_acknowledged @end)
                                    (_.set_label @end)))))))))

(the (when_i64|look_up expression archive [input every_case else])
  (Expression [Term (List [i/32.Number Term]) Term])
  (monad.let [! phase.monad]
    [input (expression archive input)
     every_case (list.each' ! (function (_ [when then])
                                (by ! each
                                    (|>> [when])
                                    (expression archive then)))
                            every_case)
     else (expression archive else)]
    (pure (monad.let [! _.monad]
            [@pre_else _.new_label
             @else _.new_label
             @end _.new_label
             every_case (list.each' ! (function (_ [when then])
                                        (monad.let !
                                          [@then _.new_label]
                                          (pure [when @then then])))
                                    every_case)]
            (all _.composite
                 input (//value.primitive type.long)
                 _.dup2 (_.long (i/32.as i/32.maximum)) _.lcmp (_.ifgt @pre_else)
                 _.dup2 (_.long (i/32.as i/32.minimum)) _.lcmp (_.iflt @pre_else)
                 _.l2i (_.lookupswitch @else (list:each (function (_ [when @then then]) [when @then]) every_case))
                 (list.mix (function (_ [when @then then] else)
                             (all _.composite
                                  (_.set_label @then)
                                  then
                                  (_.when_continuous (_.goto @end))
                                  else))
                           (list.in_reverse every_case)
                           (all _.composite
                                (_.set_label @pre_else)
                                _.pop2
                                (_.set_label @else)
                                else
                                (<| (_.when_acknowledged @end)
                                    (_.set_label @end)))))))))

(the .public (when_i64 expression archive [input every_case else])
  (Expression [Term (List [I64 Term]) Term])
  (.if (.let [every_case (list:each (|>> pair.left .integer) every_case)]
         (.and (n.> 2 (list.size every_case))
               (n.= (set.size (set.of_list i.hash every_case))
                    (list.size every_case))
               (list.every? i/32.valid? every_case)))
       (.let [every_case (list.in_order (function (_ [caseL then] [caseR then])
                                          (i.< (.integer caseL) (.integer caseR)))
                                        every_case)
              minimum (.integer (pair.left (.list_item# 0 every_case)))
              maximum (.integer (pair.left (.list_item# (-- (list.size every_case)) every_case)))]
         (.if (n.= (.natural (++ (i.- minimum maximum)))
                   (list.size every_case))
              (when_i64|table expression archive [input
                                                  (i/32.of minimum)
                                                  (list:each pair.right every_case)
                                                  else])
              (when_i64|look_up expression archive [input
                                                    (list:each (function (_ [case then])
                                                                 [(i/32.of case) then])
                                                               every_case)
                                                    else])))
       (when_i64|general expression archive [input every_case else])))
