(.using
 [library
  [lux (.except and)]])

... https://en.wikipedia.org/wiki/Monoid
(every .public (Monoid it)
  (Interface
   (is it
       identity)
   (is (-> it it
           it)
       composite)))

(the .public (and left right)
  (for_any (_ left right)
    (-> (Monoid left) (Monoid right)
        (Monoid [left right])))
  (implementation
   (the identity
     [(by left identity)
      (by right identity)])
   
   (the (composite [lL rL] [lR rR])
     [(by left composite lL lR)
      (by right composite rL rR)])))
