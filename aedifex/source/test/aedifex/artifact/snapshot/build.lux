(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]
    ["[0]" equality
     ["[1]T" \\test]]]
   [error
    ["[0]" try (.use "[1]:[0]" functor)]]
   [data
    [format
     ["[0]" xml
      ["<[1]>" \\projection]]]]
   [math
    ["[0]" random (.only Random)]]
   [test
    ["_" property (.only Test)]]]]
 [\\program
  ["[0]" /]])

(the .public random
  (Random /.Build)
  random.natural)

(the .public test
  Test
  (<| (_.covering /._)
      (_.for [/.Build]
             (all _.and
                  (_.for [/.equality]
                         (equalityT.spec /.equality ..random))
                  
                  (monad.let random.monad
                    [expected ..random]
                    (_.coverage [/.as_xml /.of_xml]
                      (|> /.of_xml
                          (<xml>.value (list (/.as_xml expected)))
                          (try:each (by /.equality = expected))
                          (try.else false))))
                  ))))
