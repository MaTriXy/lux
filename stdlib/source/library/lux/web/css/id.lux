(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]]
   [data
    ["[0]" text (.open hash)
     ["%" \\injection]]]
   [macro
    ["[0]" syntax]]
   [type
    ["[0]" nominal]]
   ["[0]" meta (.only)
    ["[0]" module]
    ["[0]" code]]]])

(nominal.every .public ID
               Text

               (the .public id
                    (-> ID
                        Text)
                    (|>> nominal.as))

               (the .public custom
                    (-> Text
                        ID)
                    (|>> nominal.of))

               (syntax.the .public (generic [])
                           (monad.let meta.monad
                                      [[module _] module.current
                                       id meta.seed]
                                      (pure (list (` (..custom (, (code.text (text "i" (%.natural_16 id)
                                                                                   "_" (%.natural_16 (text:hash module)))))))))))
               )
