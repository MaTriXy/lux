(.using
 [library
  [lux (.except with)
   [abstract
    ["<>" projection (.use functor)]]
   [meta
    ["[0]" code (.only)
     ["<[1]>" \\projection (.only Projection)]]]]])

(every .public Policy
  Code)

(the .public default
  Policy
  (` .private))

(the by_literal
  (Projection Policy)
  (<>:each code.bit <code>.bit))

(the by_reference
  (Projection Policy)
  (<>:each code.name <code>.global))

(the policy
  (Projection Policy)
  (<>.else ..default
           (all <>.either
                ..by_literal
                ..by_reference
                )))

(the .public with
  (for_any (_ it)
    (-> (Projection it)
        (Projection [Policy it])))
  (<>.and ..policy))
