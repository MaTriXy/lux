(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad (.only)
     ["[1]T" \\test]]
    ["[0]" functor
     ["[1]T" \\test (.only Injection Comparison)]]]
   [data
    [text
     ["%" \\injection]]]
   [math
    ["[0]" random]
    [number
     [/64
      ["n" natural]]]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" /]]
 ["[0]" /
  ["[1][0]" delimited]])

(the injection
  (for_any (_ o)
    (Injection (for_any (_ i)
                 (/.Cont i o))))
  (by /.monad pure))

(the comparison
  (Comparison /.Cont)
  (function (_ == left right)
    (== (/.value left) (/.value right))))

(the .public test
  Test
  (<| (_.covering /._)
      (_.for [/.Cont])
      (with "/:[0]" /.monad)
      (monad.let random.monad
        [sample random.natural])
      (all _.and
           (_.for [/.functor]
                  (functorT.spec ..injection ..comparison /.functor))
           (_.for [/.monad]
                  (monadT.spec ..injection ..comparison /.monad))

           (_.coverage [/.Context
                        /.empty]
             (|> (/:pure sample)
                 (/.continued /.empty)
                 (identical? sample)))
           (_.coverage [/.continued]
             (/.continued (identical? sample)
                          (is (/.Cont Natural Bit)
                              (function (_ next)
                                (next sample)))))
           (_.coverage [/.value]
             (n.= sample (/.value (/:pure sample))))
           (_.coverage [/.with_current /.call/cc]
             (and (n.= (n.x 2 sample)
                       (/.value (monad.let [! /.monad]
                                  [value (/.with_current
                                           (function (_ k)
                                             (monad.let !
                                               [temp (k sample)]
                                               (comment "If this code where to run,"
                                                        "the output would be"
                                                        (n.x 4 sample)

                                                        (k temp)))))]
                                  (pure (n.x 2 value)))))
                  (identical? /.with_current /.call/cc)))
           (_.coverage [/.pending]
             (/.continued (identical? sample)
                          (is (/.Cont Natural Bit)
                              (/.pending sample))))

           /delimited.test
           )))
