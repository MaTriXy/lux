(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]]
   [data
    [collection
     ["[0]" list]
     ["[0]" set]]]
   [math
    ["[0]" random (.only Random)]
    [number
     [/64
      ["[0]" natural]]]]
   [macro
    ["[0]" expansion]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" /]])

(the .public test
  Test
  (<| (_.covering /._)
      (monad.let [! random.monad]
        [])
      (_.for [/.Balance])
      (all _.and
           (expansion.let [<options> (these /.left
                                            /.right
                                            /.center)]
             (_.coverage [<options>]
               (let [options (is (List /.Balance)
                                 (list <options>))
                     uniques (set.of_list natural.hash options)]
                 (natural.= (list.size options)
                            (set.size uniques)))))
           )))
