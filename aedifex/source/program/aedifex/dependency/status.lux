(.using
 [library
  [lux (.except)
   [abstract
    [equality (.only Equality)]]
   [data
    [binary (.only Binary)]
    ["[0]" case]
    ["[0]" pair]]]]
 ["[0]" ///
  ["[1][0]" hash (.only Hash SHA1 MD5)]])

(every .public Status
  (Variant
   {:Unverified}
   {:Partial (Either (Hash SHA1)
                     (Hash MD5))}
   {:Verified (Hash SHA1) (Hash MD5)}))

(the any_equality
  (Equality Any)
  (implementation
   (the (= _ _)
     true)))

(the .public equality
  (Equality Status)
  (all case.equality
       ..any_equality
       (all case.equality
            ///hash.equality
            ///hash.equality)
       (all pair.equality
            ///hash.equality
            ///hash.equality)
       ))

(alias [=]
       ..equality)

(the .public (verified payload)
  (-> Binary Status)
  {:Verified
   (///hash.sha1 payload)
   (///hash.md5 payload)})
