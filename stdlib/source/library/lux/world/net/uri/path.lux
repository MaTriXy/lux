(.using
 [library
  [lux (.except)
   [data
    [text
     ["%" \\injection]]
    [collection
     ["[0]" list]]]]])

(every .public Segment
       Text)

(comment "https://en.wikipedia.org/wiki/Uniform_Resource_Identifier"
         (every .public Path
                Text))

(comment "https://en.wikipedia.org/wiki/Delimiter"
         (the .public delimiter
              Text
              "/"))

(the .public (path it)
     (-> (List Segment)
         Path)
     (list.mix (function (_ head tail)
                         (text ..delimiter head tail))
               it
               ""))
