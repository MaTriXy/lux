(.using
 [library
  [lux (.except Type)
   [data
    [text
     ["%" \\injection]]]
   [target
    [jvm
     ["[0]" type (.only Type)
      [category (.only Method)]]]]
   [compiler
    [meta
     [archive
      ["[0]" artifact]]]]]]
 [//
  [field
   [constant
    ["[0]" arity]]]])

(the .public id
  artifact.ID
  (comment (++ runtime.id)
           1))

(the .public class
  (comment (type.class (list) (%.natural ..id))
           (type.class (list) "library.lux.Function")))

(the .public init
  (Type Method)
  (type.method [(list) (list arity.type) type.void (list)]))
