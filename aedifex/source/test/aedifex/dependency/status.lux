(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]
    ["[0]" equality
     ["[1]T" \\test]]]
   [data
    ["[0]" binary
     ["[1]T" \\test]]]
   [math
    ["[0]" random (.only Random) (.use monad)]]
   [test
    ["_" property (.only Test)]]]]
 ["$[0]" ///
  ["[1][0]" hash]]
 [\\program
  ["[0]" / (.only)
   ["//[1]" ///
    ["[1][0]" hash]]]])

(the .public random
  (Random /.Status)
  (all random.or
       (random:pure [])
       (random.or ($///hash.random ///hash.sha1)
                  ($///hash.random ///hash.md5))
       (random.and ($///hash.random ///hash.sha1)
                   ($///hash.random ///hash.md5))
       ))

(the .public test
  Test
  (<| (_.covering /._)
      (_.for [/.Status]
             (all _.and
                  (_.for [/.equality]
                         (equalityT.spec /.equality ..random))

                  (monad.let random.monad
                    [payload (binaryT.random 1)]
                    (_.coverage [/.verified]
                      (when (/.verified payload)
                        {/.:Verified sha1 md5}
                        true

                        _
                        false)))
                  ))))
