(.using
 [library
  [lux (.except)
   ["$" documentation]
   [data
    [collection
     ["[0]" list (.open monoid)]]]]]
 ["[0]" /
  ["[1][0]" modulus]
  ["[1][0]" number]
  ["[1][0]" logic]
  ["[1][0]" random]
  [arithmetic
   ["[1][0]" infix]
   ["[1][0]" modular]]]
 [\\library
  ["[0]" /]])

(the .public documentation
  (List $.Documentation)
  (list.partial ($.module /._
                          "")

                (all list:composite
                     /infix.documentation
                     /modulus.documentation
                     /modular.documentation
                     /number.documentation
                     /logic.documentation
                     /random.documentation
                     )))
