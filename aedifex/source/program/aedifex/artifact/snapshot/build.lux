(.using
 [library
  [lux (.except)
   [abstract
    [equality (.only Equality)]
    ["<>" projection]]
   [data
    ["[0]" text
     ["%" \\injection]
     ["<[1]>" \\projection]]
    [format
     ["[0]" xml (.only XML)
      ["<[1]>" \\projection (.only Projection)]]]]
   [math
    [number
     [/64
      ["[0]" natural]]]]]])

(every .public Build
  Natural)

(the .public equality
  (Equality Build)
  natural.equality)

(alias [=]
       ..equality)

(the tag
  xml.Tag
  ["" "buildNumber"])

(the .public as_xml
  (-> Build
      XML)
  (|>> %.natural
       {xml.:Text}
       list
       {xml.:Node ..tag xml.attributes}))

(the .public of_xml
  (Projection Build)
  (<| (<xml>.node ..tag)
      (<text>.then (<>.of natural.base_10 (<text>.many <text>.base_10)))
      <xml>.text))
