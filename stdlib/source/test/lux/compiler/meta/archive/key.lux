(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]]
   [math
    ["[0]" random]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" /]]
 ["[0]" //
  ["[1][0]" signature]])

(the .public test
  Test
  (<| (_.covering /._)
      (_.for [/.Key])
      (monad.let random.monad
        [expected //signature.random
         document random.natural]
        (all _.and
             (_.coverage [/.key /.signature]
               (|> document
                   (/.key expected)
                   /.signature
                   (identical? expected)))
             ))))
