(.using
 [library
  [lux (.except)
   [abstract
    [equality (.only Equality)]]
   [data
    [binary
     [\\injection (.only Injection)]]]
   [math
    [random (.only Random)]]]]
 [//
  [utf8 (.only UTF8)]
  [//
   ["[0]" index (.only Index)]]])

(every .public String
  (Index UTF8))

(the .public equality
  (Equality String)
  index.equality)

(alias [=]
       ..equality)

(the .public as_binary
  (Injection String)
  index.as_binary)

(the .public random
  (Random String)
  index.random)
