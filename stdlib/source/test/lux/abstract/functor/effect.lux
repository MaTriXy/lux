(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" functor]
    ["[0]" monad]]
   [function
    [poly
     ["[0]" type]]]
   [math
    ["[0]" random]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" /]])

(the .public test
  Test
  (<| (_.covering /._)
      (monad.let [! random.monad]
        [])
      (_.for [/.Effect])
      (all _.and
           (_.coverage [/.functor]
             true)
           (_.coverage [/.Or /.or]
             (and (identical? type.Sum /.Or)
                  (identical? functor.sum /.or)))
           )))
