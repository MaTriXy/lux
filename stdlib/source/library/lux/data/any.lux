(.using
 [library
  [lux (.except)
   [abstract
    [equality (.only Equality)]
    [hash (.only Hash)]]]])

(the .public any
  Any
  [])

(the .public equality
  (Equality Any)
  (implementation
   (the (= _ _)
     true)))

(alias [=]
       ..equality)

(the .public hash
  (Hash Any)
  (implementation
   (the equality
     ..equality)
   
   (the (hash _)
     1)))
