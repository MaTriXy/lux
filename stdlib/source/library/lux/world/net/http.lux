(.using
 [library
  [lux (.except)
   [error
    [try (.only Try)]]
   [data
    [binary (.only Binary)]]]]
 [/
  [header (.only Headers)]])

(every .public Method
  (Variant
   {:Post}
   {:Get}
   {:Put}
   {:Patch}
   {:Delete}
   {:Head}
   {:Connect}
   {:Options}
   {:Trace}))

(every .public (Body !)
  (-> (Maybe Natural)
      (! (Try [Natural Binary]))))

(every .public (Message !)
  (Record
   [:headers Headers
    :body (Body !)]))
