(.using
 [library
  [lux (.except)
   ["$" documentation]
   [data
    [collection
     ["[0]" list (.open monoid)]]]]]
 ["[0]" /
  ["[1][0]" continuous]
  ["[1][0]" fuzzy]])

(the .public documentation
  (List $.Documentation)
  (all list:composite
       /continuous.documentation
       /fuzzy.documentation
       ))
