(.using
 [library
  [lux (.except)
   ["$" documentation]]]
 [\\library
  ["[0]" /]])

(the .public documentation
  (List $.Documentation)
  (list ($.module /._
                  "")

        ($.definition /.functor)
        ($.definition /.monad)
        ($.definition /.comonad)

        ($.definition (/.Identity it)
          "A value, as is, without any extra structure super-imposed on it.")
        ))
