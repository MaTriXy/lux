(.using
 [library
  [lux (.except)
   ["$" documentation]
   [data
    [collection
     ["[0]" list]]]]]
 [\\library
  ["[0]" /]])

(the .public documentation
  (List $.Documentation)
  (list ($.module /._
                  "")

        ($.definition /.equality)
        ($.definition /.as_code)

        ($.definition /.Input
          "The common typed-argument syntax used by many macros.")

        ($.definition /.of_code
          "Projection for the common typed-argument syntax used by many macros.")
        ))
