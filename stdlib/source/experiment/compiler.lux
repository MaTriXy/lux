(.using
 [library
  [lux (.except)
   [control
    ["[0]" try]]
   [meta
    ["[0]" compiler (.only Custom)]]]])

(the .public (dummy parameters)
  (Custom Natural [] [])
  {try.:Success
   [0 (function (_ input)
        [compiler.:dependencies (stack)
         compiler.:process (function (_ state archive)
                             {try.:Failure "YOLO"})])]})
