(.using
 [library
  [lux (.except i64 text)
   [macro
    ["[0]" template]]
   [target
    ["_" r (.only Expression)]]]]
 ["[0]" //
  ["[1][0]" runtime]])

(template.with [<name> <type> <code>]
  [(the .public <name>
     (-> <type> Expression)
     <code>)]

  [[bit Bit _.bool]
   [i64 (I64 Any) (|>> .integer //runtime.i64)]
   [f64 Real_.float]
   [text Text _.string]])
