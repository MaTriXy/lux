(.using
 [library
  [lux (.except)
   [concurrency
    ["[0]" future (.only Future)]]
   [error
    [try (.only Try)]]
   ["[0]" meta
    ["[1]/[0]" version]]
   [compiler
    ["[0]" version]]
   [world
    ["[0]" console (.only Console)]]]]
 [///
  [command (.only Command)]])

(the .public (do! console profile)
  (-> (Console Future) (Command Any))
  (is (Future (Try Any))
      (console.write_line (version.as_text meta/version.latest)
                          console)))
