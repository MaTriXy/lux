(.using
 [library
  [lux (.except)
   [abstract
    [monoid (.only Monoid)]]
   [transduction (.only Reduction)]]]
 ["[0]" //])

(every .public (Mix context)
  (for_any (_ whole piece)
    (-> (Reduction whole piece)
        (Reduction whole (context piece)))))

(the .public (with_monoid monoid mix value)
  (for_any (_ ! it)
    (-> (Monoid it) (Mix !) (! it)
        it))
  (<| (with "/:[0]" monoid)
      (mix /:composite value /:identity)))

(the .public (constant value _ init)
  (for_any (_ it)
    (Mix (//.Constant it)))
  init)

(the .public (variable value it init)
  (Mix //.Variable)
  (value it init))

(the .public (sum left right)
  (for_any (_ left right)
    (-> (Mix left) (Mix right)
        (Mix (//.Sum left right))))
  (function (_ value it init)
    (when it
      {0b it}
      (left value it init)
      
      {1b it}
      (right value it init))))

(the .public (product left right)
  (for_any (_ left right)
    (-> (Mix left) (Mix right)
        (Mix (//.Product left right))))
  (function (_ value [left_it right_it])
    (|>> (left value left_it)
         (right value right_it))))

(the .public (recursive body)
  (for_any (_ it)
    (-> (Change (Mix it))
        (Mix it)))
  (function (recursion value it init)
    ((body recursion) value it init)))
