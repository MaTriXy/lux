(.using
 [library
  [lux (.except :Local)
   [abstract
    [equality (.only Equality)]]
   [data
    ["[0]" sum]
    ["[0]" text]]
   [world
    [file (.only Path)]
    [net (.only URL)]]]])

(every .public Origin
  (Variant
   {:Local Path}
   {:Remote URL}))

(the .public equality
  (Equality Origin)
  (all sum.equality
       text.equality
       text.equality
       ))

(alias [=]
       ..equality)
