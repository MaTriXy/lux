(.using
 [library
  [lux (.except)
   ["[0]" ffi]
   [abstract
    ["[0]" monad]]
   [math
    ["[0]" random (.only Random)]
    [number
     [/64
      ["r" real]]]]
   [macro
    ["[0]" template]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" /]])

(the margin_of_error
  +0.0000001)

(the (symmetry forward backward angle)
  (-> (-> /.Angle Real) (-> Real /.Angle) /.Angle Bit)
  (let [normal (|> angle
                   forward
                   backward)]
    (|> normal
        forward
        backward
        (r.approximately? ..margin_of_error normal))))

(the .public test
  Test
  (<| (_.covering /._)
      (all _.and
           (monad.let [! random.monad]
             [.let [~= (r.approximately? ..margin_of_error)]
              angle (|> random.unit_real (by ! each (r.x /.tau)))]
             (`` (all _.and
                      (,, (template.with [,short ,arc_short
                                          ,long ,arc_long]
                            [(_.coverage [,short ,arc_short
                                          ,long ,arc_long]
                               (and (..symmetry ,short ,arc_short angle)
                                    (identical? ,short ,long)
                                    (identical? ,arc_short ,arc_long)))]

                            [[/.sin /.asin
                              /.sine /.arc_sine]
                             [/.cos /.acos
                              /.co_sine /.arc_co_sine]
                             [/.tan /.atan
                              /.tangent /.arc_tangent]
                             [/.cot /.acot
                              /.co_tangent /.arc_co_tangent]
                             [/.sec /.asec
                              /.secant /.arc_secant]
                             [/.csc /.acsc
                              /.co_secant /.arc_co_secant]]))
                      (_.coverage [/.tau]
                        (and (and (~= +0.0 (/.sin /.tau))
                                  (~= +1.0 (/.cos /.tau)))
                             (and (~= +0.0 (/.sin (r./ +2.0 /.tau)))
                                  (~= -1.0 (/.cos (r./ +2.0 /.tau))))
                             (and (~= +1.0 (/.sin (r./ +4.0 /.tau)))
                                  (~= +0.0 (/.cos (r./ +4.0 /.tau))))
                             (and (~= -1.0 (/.sin (r.x +3.0 (r./ +4.0 /.tau))))
                                  (~= +0.0 (/.cos (r.x +3.0 (r./ +4.0 /.tau)))))
                             (let [x2+y2 (r.+ (r.^ +2.0 (/.sin angle))
                                              (r.^ +2.0 (/.cos angle)))]
                               (~= +1.0 x2+y2))))
                      (_.coverage [/.pi]
                        (~= (r./ +2.0 /.tau)
                            /.pi))
                      )))
           (monad.let [! random.monad]
             [x (by ! each (|>> (r.x +10.0) r.absolute) random.unit_real)
              y (by ! each (|>> (r.x +10.0) r.absolute) random.unit_real)]
             (_.coverage [/.hypotenuse]
               (let [h (/.hypotenuse x y)]
                 (and (r.>= x h)
                      (r.>= y h)))))
           (monad.let [! random.monad]
             [.let [~= (r.approximately? ..margin_of_error)
                    tau/4 (r./ +4.0 /.tau)]
              x (by ! each (r.x tau/4) random.unit_real)
              y (by ! each (r.x tau/4) random.unit_real)]
             (_.coverage [/.atan_2
                          /.arc_tangent_2]
               (and (let [expected (/.atan_2 x y)
                          actual (if (r.> +0.0 x)
                                     (/.atan (r./ x y))
                                     (if (r.< +0.0 y)
                                         (r.- /.pi (/.atan (r./ x y)))
                                         (r.+ /.pi (/.atan (r./ x y)))))]
                      (and (~= expected actual)
                           (~= tau/4 (/.atan_2 +0.0 (r.absolute y)))
                           (~= (r.opposite tau/4) (/.atan_2 +0.0 (r.opposite (r.absolute y))))
                           (r.not_a_number? (/.atan_2 +0.0 +0.0))))
                    (identical? /.atan_2 /.arc_tangent_2))))
           (<| (_.for [/.Angle])
               (`` (all _.and
                        (,, (template.with [,factor ,unit]
                              [(_.coverage [,unit]
                                 (r.approximately? ..margin_of_error /.tau (r.x ,factor ,unit)))]

                              [[+1.0 /.turn]
                               [/.tau /.radian]
                               [+360.0 /.degree]
                               [+400.0 /.gradian]]))
                        )))
           )))
