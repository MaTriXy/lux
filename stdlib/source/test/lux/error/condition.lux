(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]]
   [function
    [poly
     [morph
      ["[0]" subject]]]]
   [math
    ["[0]" random (.only Random)]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" /]])

(the .public test
  Test
  (<| (_.covering /._)
      (monad.let [! random.monad]
        [])
      (_.for [/.Condition])
      (all _.and
           (_.coverage [/.the]
             (identical? subject.the /.the))
           (_.coverage [/.let]
             (identical? subject.let /.let))
           (_.coverage [/.value]
             (identical? subject.value /.value))
           )))
