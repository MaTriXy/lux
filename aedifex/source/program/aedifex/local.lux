(.using
 [library
  [lux (.except)
   [data
    [text
     ["%" \\injection]]]
   [world
    [net
     [uri (.only URI)
      ["[0]" path]]]]]]
 ["[0]" //
  ["[1][0]" artifact (.only Version Artifact)]])

(the / path.delimiter)

(the .public repository
  URI
  (text ".m2" / "repository"))

(the .public (uri version artifact)
  (-> Version Artifact URI)
  (text ..repository / (//artifact.uri version artifact)))
