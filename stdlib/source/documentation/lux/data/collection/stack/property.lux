(.using
 [library
  [lux (.except)
   ["$" documentation]
   [data
    [text (.only \n)
     ["%" \\injection]]]]]
 [\\library
  ["[0]" /]])

(the .public documentation
  (.List $.Documentation)
  (list ($.module /._
                  "")

        ($.definition /.empty)
        ($.definition /.size)
        ($.definition /.empty?)
        ($.definition /.domain)
        ($.definition /.values)
        ($.definition /.equality)

        ($.definition (/.List it)
          (text "A property list."
                \n "It's a simple dictionary-like structure with Text keys."))

        ($.definition /.value
          ""
          ($.example (' (value key properties))))

        ($.definition /.contains?
          ""
          ($.example (' (contains? key properties))))

        ($.definition /.has
          ""
          ($.example (' (has key val properties))))

        ($.definition /.revised
          ""
          ($.example (' (revised key f properties))))

        ($.definition /.lacks
          ""
          ($.example (' (lacks key properties))))
        ))
