(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]
    ["[0]" equality
     ["[1]T" \\test]]]
   [error
    ["[0]" try (.use functor)]]
   [data
    [format
     ["[0]" xml
      ["<[1]>" \\projection]]]
    [collection
     ["[0]" list]]]
   [math
    ["[0]" random (.only Random)]]
   [time
    ["[0]" instant]]
   [test
    ["_" property (.only Test)]]]]
 [\\program
  ["[0]" /]]
 ["$[0]" //
  ["[1][0]" time]
  ["[1][0]" build]])

(the .public random
  (Random /.Stamp)
  (all random.and
       $//time.random
       $//build.random
       ))

(the .public test
  Test
  (<| (_.covering /._)
      (_.for [/.Stamp])
      (all _.and
           (_.for [/.equality]
                  (equalityT.spec /.equality ..random))

           (monad.let random.monad
             [expected ..random]
             (_.coverage [/.as_xml /.of_xml]
               (|> /.of_xml
                   (<xml>.value (/.as_xml expected))
                   (try:each (by /.equality = expected))
                   (try.else false))))
           )))
