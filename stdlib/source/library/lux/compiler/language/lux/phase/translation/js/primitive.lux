(.using
 [library
  [lux (.except i64 text)
   [target
    ["_" js (.only Computation)]]]]
 ["[0]" //
  ["[1][0]" runtime]])

(the .public bit
  _.boolean)

(the .public (i64 value)
  (-> I64
      Computation)
  (//runtime.i64 (|> value //runtime.high .integer _.i32)
                 (|> value //runtime.low .integer _.i32)))

(the .public f64
  _.number)

(the .public text
  _.string)
