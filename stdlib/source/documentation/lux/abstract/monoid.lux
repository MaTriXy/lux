(.using
 [library
  [lux (.except)
   ["$" documentation]
   [data
    [text (.only \n)
     ["%" \\injection]]]]]
 [\\library
  ["[0]" /]])

(the .public documentation
  (List $.Documentation)
  (list ($.module /._
                  "")

        ($.definition /.and)

        ($.definition (/.Monoid it)
          (text "A way to compose values."
                \n "Includes an identity value which does not alter any other value when combined with."))
        ))
