(.using
 [library
  [lux (.except)
   ["$" documentation]
   [data
    [text (.only \n)
     ["%" \\injection]]]
   [math
    [number
     ["[0]" fraction]]]
   [meta
    [macro
     ["[0]" template]]]]]
 [\\library
  ["[0]" /]])

(`` (the .public documentation
      (List $.Documentation)
      (list ($.module /._
                      "")

            ($.definition /.Gram)
            ($.definition /.Meter)
            ($.definition /.Litre)
            ($.definition /.Second)
            ($.definition /.number)
            ($.definition /.equality)
            ($.definition /.order)
            ($.definition /.enum)
            ($.definition /.+)
            ($.definition /.-)
            ($.definition /.x)
            ($.definition /./)

            ($.definition (/.Measure unit)
              "A quantity with an associated unit of measurement.")

            ($.definition (/.Unit unit)
              "A unit of measurement, to qualify numbers with.")

            ($.definition /.unit
              (text "Define a unit of measurement."
                    \n "Both the name of the type, and the name of the Unit implementation must be specified.")
              ($.example (' (the feet (unit [])))))

            (,, (template.with [<unit>]
                  [(`` ($.definition <unit>
                         (text "The '" (,, (template.text [<unit>])) "' unit of meaurement.")))]

                  [[/.gram]
                   [/.meter]
                   [/.litre]
                   [/.second]]
                  ))
            )))
