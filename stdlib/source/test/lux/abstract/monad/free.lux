(.using
 [library
  [lux (.except)
   [abstract
    [functor (.only Functor)]
    [monad (.only Monad)]
    ["[0]" functor
     ["[1]T" \\test (.only Injection Comparison)]]]
   [data
    [collection
     ["[0]" list (.use monad)]]]
   [math
    ["[0]" random]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" /]])

(the injection
  (Injection (/.Free List))
  (|>> {/.:Pure}))

(the (interpret free)
  (for_any (_ it)
    (-> (/.Free List it)
        (List it)))
  (when free
    {/.:Pure value}
    (list value)
    
    {/.:Impure effect}
    (|> effect
        (list:each interpret)
        list:conjoint)))

(the comparison
  (Comparison (/.Free List))
  (function (_ = left right)
    (by (list.equality =) =
        (..interpret left)
        (..interpret right))))

(the .public (test spec)
  (-> (for_any (_ !)
        (-> (Injection !) (Comparison !) (Monad !)
            Test))
      Test)
  (<| (_.covering /._)
      (_.for [/.Free
              /.:Pure /.:Impure])
      (all _.and
           (_.for [/.functor]
                  (functorT.spec ..injection ..comparison (is (Functor (/.Free List))
                                                              (/.functor list.functor))))
           (_.for [/.monad]
                  (spec ..injection ..comparison (is (Monad (/.Free List))
                                                     (/.monad list.functor))))
           )))
