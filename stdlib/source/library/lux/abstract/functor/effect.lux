(.using
 [library
  [lux (.except Or)
   [function
    [poly
     ["[0]" type]]]]]
 ["[0]" // (.only Functor)])

(every .public (Effect input output !)
       [input (-> output !)])

(the .public functor
     (for_any (_ input output)
              (Functor (Effect input output)))
     (implementation
      (the (each on [input next])
           [input (|>> next on)])))

(the .public Or
     type.Sum)

(the .public or
     //.sum)
