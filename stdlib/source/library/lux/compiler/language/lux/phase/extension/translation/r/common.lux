(.using
 [library
  [lux (.except)
   [abstract
    ["<>" projection]
    ["[0]" monad]]
   [error
    ["[0]" try]]
   ["[0]" function]
   [data
    [collection
     ["[0]" dictionary]
     ["[0]" set]
     ["[0]" stack (.use functor mix)]]]
   [macro
    ["[0]" template]]
   [target
    ["_" r]]]]
 ["[0]" ////
  ["/" bundle]
  ["/[1]" //
   ["[0]" extension]
   [translation
    [extension (.only Nullary Unary Binary Trinary
                      nullary unary binary trinary)]
    ["[0]" reference]
    ["//" r
     ["[1][0]" runtime (.only Operation Phase Handler Bundle)]
     ["[1][0]" when]]]
   [//
    ["[0]" synthesis
     ["<s>" \\projection]]
    ["[0]" translation]
    [///
     ["[1]" phase]]]]])

(the i64_procs
  Bundle
  (<| (/.prefix "i64")
      (|> /.empty
          (/.install "char" (unary (|>> //runtime.i64_low _.intToUtf8/1)))
          )))

(the text_procs
  Bundle
  (<| (/.prefix "text")
      (|> /.empty
          (/.install "concat" (binary _.paste/2))
          )))

(the .public bundle
  Bundle
  (<| (/.prefix "lux")
      (|> /.empty
          (dictionary.composite i64_procs)
          (dictionary.composite text_procs))))
