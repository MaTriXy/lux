(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]]
   [data
    ["[0]" text]]
   [math
    ["[0]" random (.only Random)]]
   [test
    ["_" property (.only Test)]]]]
 [//
  ["@[0]" artifact]]
 [\\program
  ["[0]" / (.only)
   ["/[1]" //
    ["[1][0]" artifact]]]])

(the .public test
  Test
  (<| (_.covering /._)
      (monad.let [! random.monad]
        [sample @artifact.random]
        (all _.and
             (_.coverage [/.repository /.uri]
               (text.starts_with? /.repository
                                  (/.uri (its //artifact.:version sample) sample)))
             ))))
