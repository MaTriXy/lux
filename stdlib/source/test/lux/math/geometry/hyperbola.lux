(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]]
   [math
    ["[0]" random]
    [number
     [/64
      ["r" real]]]
    [geometry
     ["[0]" circle]]]
   [macro
    ["[0]" template]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" /]])

(the margin_of_error
  +0.0000001)

(the .public test
  Test
  (<| (_.covering /._)
      (monad.let [! random.monad]
        [.let [~= (r.approximately? ..margin_of_error)]
         angle (by ! each (r.x circle.tau) random.unit_real)
         sample (by ! each r.absolute random.unit_real)
         big (by ! each (r.x +1,000,000,000.00) random.unit_real)]
        (template.let [(odd! ,function ,alias)
                       [(_.coverage [,function
                                     ,alias]
                          (and (~= (r.opposite (,function angle))
                                   (,function (r.opposite angle)))
                               (identical? ,alias ,function)))]

                       (even! ,function ,alias)
                       [(_.coverage [,function
                                     ,alias]
                          (and (~= (,function angle)
                                   (,function (r.opposite angle)))
                               (identical? ,alias ,function)))]

                       (inverse! ,left ,right ,input ,left_alias ,right_alias)
                       [(_.coverage [,left ,right
                                     ,left_alias ,right_alias]
                          (and (~= (,right ,input)
                                   (,left (r./ ,input +1.0)))
                               (identical? ,left ,left_alias)
                               (identical? ,right ,right_alias)))]]
          (all _.and
               (odd! /.sine /.sin)
               (even! /.co_sine /.cos)
               (odd! /.tangent /.tan)
               (odd! /.co_tangent /.cot)
               (even! /.secant /.sec)
               (odd! /.co_secant /.csc)

               (inverse! /.arc_co_sine /.arc_secant sample /.acos /.asec)
               (inverse! /.arc_sine /.arc_co_secant sample /.asin /.acsc)
               (inverse! /.arc_tangent /.arc_co_tangent big /.atan /.acot)
               )))))
