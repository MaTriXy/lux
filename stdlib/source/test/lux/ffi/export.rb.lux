(.using
 [library
  [lux (.except)
   [math
    [number
     [/64
      ["n" natural]]]]
   [macro
    ["[0]" expansion]]
   [meta
    ["[0]" static]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" / (.only)
   ["/[1]" //]]])

(expansion.let [<natural> (static.random_natural)]
  (these (/.export
          (the nullary
            Natural
            <natural>)
          (the unary
            (-> Natural Natural)
            (|>> (n.+ <natural>)))
          (the CONSTANT
            Natural
            <natural>)
          (the $global
            (-> Natural Natural)
            (|>> (n.+ <natural>))))

         (//.the (nullary [] Natural))
         (//.the (unary [Natural] Natural))
         (//.the (CONSTANT Natural))
         (//.the ($global (-> Natural Natural)))

         (the .public test
           Test
           (<| (_.covering /._)
               (all _.and
                    (_.coverage [/.export]
                      (and (n.= <natural> (..nullary []))
                           (n.= (n.+ <natural> <natural>) (..unary <natural>))
                           (n.= <natural> (..CONSTANT))
                           (n.= (n.+ <natural> <natural>) ((..$global) <natural>))))
                    ))))
  )
