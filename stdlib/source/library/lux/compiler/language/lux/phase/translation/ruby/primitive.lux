(.using
 [library
  [lux (.except i64 text)
   [macro
    ["[0]" template]]
   [target
    ["_" ruby (.only Literal)]]]])

(template.with [<type> <name> <implementation>]
  [(the .public <name>
     (-> <type>
         Literal)
     <implementation>)]

  [[Bit bit _.bool]
   [I64 i64 (|>> .integer _.int)]
   [Real f64 _.float]
   [Text text _.string]])
