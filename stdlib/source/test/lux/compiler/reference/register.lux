(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]]
   [math
    ["[0]" random (.only Random)]
    [number
     [/64
      ["[0]" natural]]]]
   [test
    ["_" property (.only Test)]]
   [compiler
    ["@[0]" type]]]]
 [\\library
  ["[0]" /]])

(the .public test
  Test
  (<| (_.covering /._)
      (monad.let [! random.monad]
        [it random.natural])
      (_.for [@type.Register])
      (all _.and
           (_.coverage [/.first]
             (not (natural.< /.first it)))
           )))
