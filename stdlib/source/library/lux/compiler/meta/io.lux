(.using
 [library
  [lux (.except Code)
   [data
    ["[0]" text]]
   [world
    ["[0]" file]]
   [meta
    ["[0]" module]]]]
 [//
  [archive
   [module
    ["[0]" descriptor]]]])

(every .public Context
  file.Path)

(every .public Code
  Text)

(the .public (path fs)
  (for_any (_ !)
    (-> (file.System !) descriptor.Module
        file.Path))
  (text.replaced module.delimiter
                 (by fs delimiter)))
