(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]]
   [error
    ["[0]" try]]
   [data
    [format
     ["[0]" json (.only JSON)]]]
   [logic
    ["[0]" bit]]
   [math
    ["[0]" random (.only Random)]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" / (.only Format)
   [//
    [equality (.only Equality)]]]])

(the json
  (Format JSON Bit)
  (let [field "value"]
    (implementation
     (the as
       (|>> {json.:Boolean}
            [field]
            list
            json.object))
     (the of
       (json.boolean_field field)))))

(the format
  (Format Text Bit)
  (/.composite json.format ..json))

(the .public test
  Test
  (monad.let random.monad
    [expected random.bit]
    (<| (_.covering /._)
        (_.coverage [/.composite]
          (when (|> expected (by ..format as) (by ..format of))
            {try.:Success actual}
            (bit.= expected actual)
            
            {try.:Failure error}
            false)))))

(the .public (spec equality format generator)
  (for_any (_ m a)
    (-> (Equality a) (/.Format m a) (Random a)
        Test))
  (<| (with "/:[0]" equality)
      (with "/:[0]" format)
      (_.for [/.Format])
      (monad.let random.monad
        [expected generator])
      (_.coverage [/.as /.of]
        (when (|> expected /:as /:of)
          {try.:Success actual}
          (/:= expected actual)
          
          {try.:Failure _}
          false))))
