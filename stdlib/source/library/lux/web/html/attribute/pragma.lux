(.using
 [library
  [lux (.except)
   [data
    ["[0]" text]]
   [macro
    ["[0]" template]]]])

(every .public Pragma
  Text)

(template.with [<name>]
  [(the .public <name>
     Pragma
     (|> (template.text [<name>])
         (text.replaced "_" "-")))]

  [[content_security_policy]
   [content_type]
   [default_style]
   [x_ua_compatible]
   [refresh]])
