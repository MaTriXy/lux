(.using
 [library
  [lux (.except)
   ["$" documentation]
   [data
    [collection
     ["[0]" list]]]]]
 [\\library
  ["[0]" /]])

(the .public documentation
  (List $.Documentation)
  (list ($.module /._
                  "")

        ($.definition /.equality)
        ($.definition /.as_code)
        ($.definition /.of_code)

        ($.definition /.Check
          "A type annotation for an expression.")
        ))
