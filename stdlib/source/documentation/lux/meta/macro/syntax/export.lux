(.using
 [library
  [lux (.except)
   ["$" documentation]
   [data
    [collection
     ["[0]" list]]]]]
 [\\library
  ["[0]" /]])

(the .public documentation
  (List $.Documentation)
  (list ($.module /._
                  "Syntax for marking a definition as an export.")

        ($.definition /.default)

        ($.definition /.with
          ""
          ($.example (' (with un_exported))))
        ))
