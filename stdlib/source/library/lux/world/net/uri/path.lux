(.using
 [library
  [lux (.except)
   [data
    [text
     ["%" \\injection]]
    [collection
     ["[0]" list (.use "[1]:[0]" mix)]]]]])

(every .public Segment
  Text)

... https://en.wikipedia.org/wiki/Uniform_Resource_Identifier
(every .public Path
  Text)

... https://en.wikipedia.org/wiki/Delimiter
(the .public delimiter
  Text
  "/")

(the .public path
  (-> (List Segment)
      Path)
  (list:mix (function (_ head tail)
              (text ..delimiter head tail))
            ""))
