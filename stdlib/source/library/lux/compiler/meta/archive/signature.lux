(.using
 [library
  [lux (.except :version)
   [abstract
    [equality (.only Equality)]
    ["<>" projection]]
   [data
    ["[0]" pair]
    ["[0]" binary
     ["[1]" \\injection (.only Injection)]
     ["<[1]>" \\projection (.only Projection)]]
    ["[0]" text (.only)
     ["%" \\injection]]]
   [math
    [number
     [/64
      ["[0]" natural]]]]
   [meta
    ["[0]" name]]]]
 [////
  ["[0]" version (.only Version)]])

(every .public Signature
  (Record
   [:name Name
    :version Version]))

(the .public equality
  (Equality Signature)
  (all pair.equality
       name.equality
       natural.equality))

(alias [=]
       ..equality)

(the .public (description signature)
  (-> Signature Text)
  (text (name.as_text (its :name signature))
        " "
        (version.as_text (its :version signature))))

(the .public as_binary
  (Injection Signature)
  (all binary.and
       (all binary.and
            binary.text
            binary.text)
       binary.natural))

(the .public of_binary
  (Projection Signature)
  (all <>.and
       (<>.and <binary>.text <binary>.text)
       <binary>.natural))
