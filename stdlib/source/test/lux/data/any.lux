(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]
    ["[0]" equality
     ["[1]T" \\test]]
    ["[0]" hash
     ["[1]T" \\test]]]
   [math
    ["[0]" random (.only Random) (.open monad)]]
   [meta
    ["[0]" static]]
   [test
    ["_" property (.only Test)]]
   ["[0]" target]]]
 [\\library
  ["[0]" /]])

(the .public random
  (Random Any)
  (random:pure /.any))

(the .public test
  Test
  (<| (_.covering /._)
      (monad.let [! random.monad]
        [])
      (all _.and
           (_.for [/.equality /.=]
                  (static.when (identical? /.equality /.=)
                    (equalityT.spec /.equality ..random)))
           (_.for [/.hash]
                  (hashT.spec /.hash ..random))
           
           (_.coverage [/.any]
             (target.if target.ruby
                        true
                        
                        ... else
                        (identical? [] /.any)))
           )))
