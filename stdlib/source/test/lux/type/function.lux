(.using
 [library
  [lux (.except general)
   [math
    ["[0]" random (.only Random) (.use "[1]:[0]" monad)]]
   [macro
    ["[0]" expansion]]
   [meta
    ["[0]" static]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" / (.only)
   ["/[1]" //]]])

(the (general _ _)
  (for_any (_ input output)
    (-> input input
        output))
  (undefined))

(the .public test
  Test
  (<| (_.covering /._)
      (expansion.let [,random (these (static.random //.code
                                                    (all random.either
                                                         (random:pure Bit)
                                                         (random:pure Natural)
                                                         (random:pure Integer)
                                                         (random:pure Revolution)
                                                         (random:pure Decimal)
                                                         (random:pure Text))))
                      ,input ,random
                      ,output ,random])
      (all _.and
           (_.coverage [/.domain]
             (//.= (Tuple ,input ,input)
                   (/.domain ..general [,input ,output])))
           (_.coverage [/.image]
             (//.= ,output
                   (/.image ..general [,input ,output])))
           )
      ))
