(.using
 [library
  [lux (.except Name name)
   [data
    ["[0]" text]]]])

(the suffix
  "#")

(every .public Name
  Text)

(the .public name
  (-> Text
      Name)
  (text.suffix ..suffix))

(the .public analysis
  (Change Name)
  (text.prefix "analysis_of_"))

(the .public synthesis
  (Change Name)
  (text.prefix "synthesis_of_"))
