(.using
 [library
  [lux (.except type)
   [math
    [number
     ["[0]" /64]]]
   [macro
    ["[0]" template]]
   [target
    [jvm
     ["[0]" type]]]]]
 ["[0]" //
  [/////////
   [arity (.only Arity)]]])

(template.with [<power> <name>]
  [(the .public <name>
     Arity
     (/64.<< <power> 1))]

  [[0 minimum]
   [3 maximum]]
  )

(the .public type
  type.int)
