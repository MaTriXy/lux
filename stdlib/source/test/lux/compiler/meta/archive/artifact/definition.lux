(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" equality
     ["[1]T" \\test]]]
   [math
    ["[0]" random (.only Random)]]
   [meta
    ["[0]" static]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" /]])

(the .public random
  (Random /.Definition)
  (all random.and
       (random.lower_cased 1)
       (random.maybe
        (all random.and
             random.natural
             random.natural
             random.natural
             ))
       ))

(the .public test
  Test
  (<| (_.covering /._)
      (_.for [/.Definition])
      (all _.and
           (_.for [/.equality /.=]
                  (static.when (identical? /.equality /.=)
                    (equalityT.spec /.equality ..random)))
           )))
