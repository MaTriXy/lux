(.using
 [library
  [lux (.except)]]
 [//
  ["[0]" equality (.only Equality)]
  [functor
   ["[0]" contravariant]]])

(every .public (Hash it)
  (Interface
   (is (Equality it)
       equality)
   (is (-> it
           Natural)
       hash)))

(the .public functor
  (contravariant.Functor Hash)
  (implementation
   (the (each f super)
     (implementation
      (the equality
        (by equality.functor each f
            (by super equality)))
      
      (the hash
        (|>> f (by super hash)))))))
