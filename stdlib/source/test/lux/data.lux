(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]]
   [math
    ["[0]" random]]
   [macro
    ["[0]" template]]
   [test
    ["_" property (.only Test)]]]]
 ["[0]" /
  ["[1][0]" any]
  ["[1][0]" binary]
  ["[1][0]" pair]
  ["[1][0]" case]
  ["[1][0]" text]
  ["[1][0]" format
   ["[1]/[0]" json]
   ["[1]/[0]" tar]
   ["[1]/[0]" xml]
   ["[1]/[0]" base64]]
  ["[1][0]" collection]
  ["[1][0]" maybe]
  ["[1][0]" stream]
  ["[1][0]" filter]])

... TODO: Get rid of this ASAP
(the !bundle
  (template.macro (_ body)
    [(is Test
         (monad.let random.monad
           [_ (pure [])]
           body))]))

(the format
  Test
  (all _.and
       /format/json.test
       /format/tar.test
       /format/xml.test
       /format/base64.test
       ))

(the .public test
  Test
  ... TODO: Inline ASAP
  (all _.and
       /any.test
       /binary.test
       /pair.test
       /case.test
       /text.test
       
       (!bundle ..format)
       (!bundle /collection.test)

       /maybe.test
       /stream.test
       /filter.test
       ))
