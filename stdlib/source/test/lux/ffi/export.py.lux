(.using
 [library
  [lux (.except)
   [math
    [number
     [/64
      ["n" natural]]]]
   [macro
    ["[0]" expansion]]
   [meta
    ["[0]" static]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" / (.only)
   ["/[1]" //]]])

(expansion.let [<natural> (static.random_natural)]
  (these (/.export
          (the constant
            Natural
            <natural>)
          (the shift
            (Change Natural)
            (|>> (n.+ <natural>))))

         (//.the (constant Natural))
         (//.the (shift (Change Natural)))

         (the .public test
           Test
           (<| (_.covering /._)
               (all _.and
                    (_.coverage [/.export]
                      (and (n.= <natural> ..constant)
                           (n.= (n.+ <natural> <natural>) (..shift <natural>))))
                    ))))
  )
