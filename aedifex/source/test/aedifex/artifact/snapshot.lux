(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]
    ["[0]" equality
     ["[1]T" \\test]]]
   [error
    ["[0]" try (.open functor)]]
   [data
    [format
     ["[0]" xml
      ["<[1]>" \\projection]]]]
   [math
    ["[0]" random (.only Random) (.open monad)]]
   [test
    ["_" property (.only Test)]]]]
 ["$[0]" /
  ["[1][0]" build]
  ["[1][0]" stamp]
  ["[1][0]" time]
  ["[1][0]" version]]
 [\\program
  ["[0]" /]])

(the .public random
  (Random /.Snapshot)
  (random.or (random:pure [])
             $/stamp.random))

(the .public test
  Test
  (<| (_.covering /._)
      (_.for [/.Snapshot]
             (all _.and
                  (_.for [/.equality]
                         (equalityT.spec /.equality ..random))
                  
                  (monad.let random.monad
                    [expected ..random]
                    (_.coverage [/.as_xml /.of_xml]
                      (|> /.of_xml
                          (<xml>.value (list (/.as_xml expected)))
                          (try:each (by /.equality = expected))
                          (try.else false))))

                  $/build.test
                  $/stamp.test
                  $/time.test
                  $/version.test
                  ))))
