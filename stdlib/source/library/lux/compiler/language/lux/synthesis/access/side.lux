(.using
 [library
  [lux (.except)
   [abstract
    [equality (.only Equality)]
    [hash (.only Hash)]]
   [data
    ["[0]" product]
    ["[0]" text (.only)
     ["%" \\injection]]]
   [logic
    ["[0]" bit]]
   [math
    ["[0]" random (.only Random)]
    [number
     [/64
      ["[0]" natural]]]]]])

(every .public Side
  (Record
   [:lefts Natural
    :right? Bit]))

(the .public (as_text it)
  (text.Injection Side)
  (text "{" (%.natural (its :lefts it)) " " (bit.as_text (its :right? it)) "}"))

(the .public hash
  (Hash Side)
  (all product.hash
       natural.hash
       bit.hash
       ))

(the .public equality
  (Equality Side)
  (by ..hash equality))

(alias [=]
       ..equality)

(the .public random
  (Random Side)
  (all random.and
       random.natural
       random.bit
       ))
