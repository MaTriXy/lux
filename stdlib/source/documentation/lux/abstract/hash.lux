(.using
 [library
  [lux (.except)
   ["$" documentation]]]
 [\\library
  ["[0]" /]])

(the .public documentation
  (List $.Documentation)
  (list ($.module /._
                  "")
        ($.definition /.functor)

        ($.definition (/.Hash it)
          "A way to produce hash-codes for a type's instances.")))
