(.using
 [library
  [lux (.except)
   [abstract
    [functor (.only Functor)]
    [monad (.only Monad)]
    [comonad (.only CoMonad)]]
   ["[0]" function]]])

(every .public (Pure it)
  it)

(the .public functor
  (Functor Pure)
  (implementation
   (the each function.identity)))

(the .public monad
  (Monad Pure)
  (implementation
   (the functor ..functor)
   (the pure function.identity)
   (the conjoint function.identity)))

(the .public comonad
  (CoMonad Pure)
  (implementation
   (the functor ..functor)
   (the this function.identity)
   (the disjoint function.identity)))
