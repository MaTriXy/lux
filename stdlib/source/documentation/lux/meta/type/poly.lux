(.using
 [library
  [lux (.except)
   ["$" documentation]]]
 [\\library
  ["[0]" /]])

(the .public documentation
  (List $.Documentation)
  (list ($.module /._
                  "")

        ($.definition /.polytypic)

        ($.definition /.code
          ""
          ($.example (' (code env type))))
        ))
