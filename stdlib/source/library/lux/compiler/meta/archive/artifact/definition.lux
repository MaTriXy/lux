(.using
 [library
  [lux (.except Definition)
   [abstract
    [equality (.only Equality)]]
   [data
    ["[0]" maybe]
    ["[0]" pair]
    ["[0]" text]]
   [math
    [number
     [/64
      ["[0]" natural]]]]]]
 [/////
  [arity (.only Arity)]])

(every .public Definition
  [Text (Maybe [Arity [Natural Natural]])])

(the .public equality
  (Equality Definition)
  (all pair.equality
       text.equality
       (maybe.equality
        (all pair.equality
             natural.equality
             natural.equality
             natural.equality
             ))
       ))

(alias [=]
       ..equality)
