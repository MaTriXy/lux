(.using
 [library
  [lux (.except Type)
   [abstract
    [equality (.only Equality)]]
   [error
    ["[0]" try]]
   [math
    ["[0]" random (.only Random) (.open monad)]
    [number
     ["[0]" /16
      ["[1]" natural]]]]
   [macro
    ["[0]" template]]]]
 [/////
  ["[0]" type (.only Type)]])

(every .public Datum
       /16.Number)

(template.with [,value ,name]
               [(the .public ,name
                     Datum
                     (/16.of ,value))]

               [[1 small]
                [2 big]])

(alias [boolean byte short int
        char
        float
        object]
       ..small)

(alias [long double]
       ..big)

(the .public equality
     (Equality Datum)
     /16.equality)

(alias [=]
       ..equality)

(the .public random
     (Random Datum)
     (all random.either
          (random:pure ..small)
          (random:pure ..big)
          ))

(the .public (for it)
     (for_any (_ it)
              (-> (Type it)
                  Datum))
     (if (and/or (identical? (is (Type Any) it) (is (Type Any) type.long))
                 (identical? (is (Type Any) it) (is (Type Any) type.double)))
         ..big
         ..small))
