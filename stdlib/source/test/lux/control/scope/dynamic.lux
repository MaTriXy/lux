(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]]
   [data
    [text
     ["%" \\injection]]]
   [math
    ["[0]" random (.only Random) (.open functor)]
    [number
     [/64
      ["n" natural]]]]
   [macro
    ["[0]" expansion]]
   [meta
    ["[0]" static]
    ["[0]" code]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" /]])

(expansion.let [<it> (static.random code.local
                                    (random:each %.natural random.natural))
                <before> (static.random_natural)]
  (these (/.the .private <it>
           Natural
           <before>)

         (the .public test
           Test
           (<| (_.covering /._)
               (monad.let [! random.monad]
                 [after (random.only (|>> (n.= <before>) not)
                                     random.natural)])
               (_.for [/.Dynamic])
               (all _.and
                    (_.coverage [/.the /.value]
                      (n.= <before> (/.value <it>)))
                    (_.coverage [/.let]
                      (|> (/.let [<it> after]
                            <it>)
                          /.value
                          (identical? after)))
                    )))))
