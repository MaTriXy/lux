(.using
 [library
  [lux (.except)
   [abstract
    [monoid (.only Monoid)]]
   [function
    [predicate (.only Predicate)]]
   [data
    ["[0]" text (.only)
     ["%" \\injection]]]
   [math
    [number
     [/64
      ["n" natural]
      ["r" real]]]]
   [macro
    ["[0]" template]]]]
 [///
  ["[0]" money (.only Money)]])

(comment "https://en.wikipedia.org/wiki/Interest_rate"
         (every .public Rate
                Real))

(comment "https://en.wikipedia.org/wiki/Break-even"
         (the .public break_even
              Rate
              +1.0))

(comment "https://en.wikipedia.org/wiki/Compound_interest"
         (the .public compound
              (-> Rate Rate
                  Rate)
              r.x))

(template.with [<order> <name>]
               [(the .public <name>
                     (Predicate Rate)
                     (<order> ..break_even))]

               [[r.< loss?]
                [r.> gain?]
                [r.= break_even?]])

(the .public monoid
     (Monoid Rate)
     (implementation
      (the identity ..break_even)
      (the composite ..compound)))

(the .public as_text
     (text.Injection Rate)
     (|>> (r.- ..break_even)
          %.per_cent))

(the .public (rate before after)
     (for_any (_ $)
              (-> (Money $) (Money $)
                  Rate))
     (r./ (n.real (money.amount before))
          (n.real (money.amount after))))
