(.using
 [library
  [lux (.except)]]
 [///
  [trade
   [session (.only Session)]]])

(comment "https://en.wikipedia.org/wiki/Ticker_symbol"
         (every .public Symbol
                Text))

(comment "https://en.wikipedia.org/wiki/Ticker_tape"
         (every .public (Tape $)
                (Stack (Session $))))
