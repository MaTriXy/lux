(.using
 [library
  [lux (.except Type)
   [macro
    ["[0]" template]]]])

... https://maven.apache.org/ref/3.6.3/maven-core/artifact-handlers.html
(every .public Type
  Text)

(template.with [<type> <name>]
  [(the .public <name>
     Type
     <type>)]

  [["tar" lux_library]
   ["jar" jvm_library]
   ["js" js_library]
   ["aar" android_archive]
   ["pom" pom]
   ["sha1" sha1]
   ["md5" md5]])
