(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]]
   [math
    ["[0]" random]]
   [test
    ["_" property (.only Test)]]
   [data
    ["[0]" text]]
   [meta
    ["[0]" module]
    ["[0]" name]]
   [macro
    ["[0]" template]]]]
 [\\library
  ["[0]" /]])

(the .public test
  Test
  (<| (_.covering /._)
      (monad.let [! random.monad]
        [])
      (`` (all _.and
               (,, (template.with [,constant ,reference]
                     [(_.coverage [,constant]
                        (text.= (`` (.constant# (,, (static ,constant))))
                                ,reference))]

                     [[/.delimiter_for_module module.delimiter]
                      [/.delimiter_for_name name.delimiter]]))
               ))))
