(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" equality
     ["[1]T" \\test]]]
   [math
    ["[0]" random (.only Random)]]
   [test
    ["_" property (.only Test)]]]]
 [\\program
  ["[0]" /]])

(the .public random
  (Random /.Origin)
  (all random.or
       (random.alphabetic 10)
       (random.alphabetic 10)
       ))

(the .public test
  Test
  (<| (_.covering /._)
      (_.for [/.Origin]
             (all _.and
                  (_.for [/.equality]
                         (equalityT.spec /.equality ..random))
                  ))))
