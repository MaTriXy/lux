(.using
 [library
  [lux (.except)
   [abstract
    [functor (.only Functor)]
    [monad (.only Monad)]
    [equality (.only Equality)]]
   [concurrency
    ["[0]" atom]]
   [control
    ["[0]" io]]
   [data
    [collection
     ["[0]" list
      ["?[1]" \\projection]]]]
   [macro (.only with_names)
    ["[0]" syntax]
    ["[0]" template]]
   [type (.only sharing)
    ["[0]" nominal]]
   [meta
    ["[0]" code
     ["<[1]>" \\projection]]]]])

(the Computation
  (template.macro (_ it)
    [(-> Any
         it)]))

(nominal.every .public (Lazy it)
  (Computation it)

  (the .public (as_lazy generator)
    (for_any (_ it)
      (-> (Computation it)
          (Lazy it)))
    (let [cache (atom.atom (sharing [it]
                             (is (Computation it)
                                 generator)
                             (is (Maybe it)
                                 {.:None})))]
      (nominal.of
       (function (_ _)
         (when (io.value (atom.read! cache))
           {.:Some value}
           value

           _
           (let [value (generator [])]
             (exec
               (io.value (atom.compare_and_swap! _ {.:Some value} cache))
               value)))))))

  (the value'
    (template.macro (_ ,it)
      [((nominal.as ,it) [])]))

  (the .public value
    (for_any (_ it)
      (-> (Lazy it)
          it))
    (|>> ..value'))

  (syntax.the .public (lazy [expression ?list.any])
    (with_names ['_]
      (pure (list (` (..as_lazy (function ((, '_) (, '_))
                                  (, expression))))))))

  (the .public (equality it)
    (for_any (_ it)
      (-> (Equality it)
          (Equality (Lazy it))))
    (with "_:[0]" it
      (implementation
       (the (= left right)
         (_:= (..value' left)
              (..value' right))))))

  (the .public functor
    (Functor Lazy)
    (implementation
     (the (each f fa)
       (lazy (f (..value' fa))))))

  (the .public monad
    (Monad Lazy)
    (implementation
     (the functor ..functor)
     (the pure (|>> lazy))
     (the conjoint ..value)))
  )
