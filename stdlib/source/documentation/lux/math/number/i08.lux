(.using
 [library
  [lux (.except)
   ["$" documentation]]]
 [\\library
  ["[0]" /]])

(the .public documentation
  (List $.Documentation)
  (list ($.module /._
                  "")

        ($.definition /.equality)
        ($.definition /.width)
        ($.definition /.i08)
        ($.definition /.i64)

        ($.definition /.I08
          "A 8-bit integer.")
        ))
