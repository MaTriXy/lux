(.using
 [library
  [lux (.except)
   [abstract
    [equality (.only Equality)]]
   [data
    ["[0]" pair]
    ["[0]" binary
     ["[1]" \\injection (.only Injection)]]]
   [math
    ["[0]" random (.only Random)]]]]
 [//
  [utf8 (.only UTF8)]
  [//
   ["[0]" index (.only Index)]
   [type
    [descriptor (.only Descriptor)]]]])

(every .public (Name_And_Type it)
  (Record
   [:name (Index UTF8)
    :descriptor (Index (Descriptor it))]))

(the .public equality
  (Equality (Name_And_Type Any))
  (all pair.equality
       index.equality
       index.equality
       ))

(alias [=]
       ..equality)

(the .public as_binary
  (Injection (Name_And_Type Any))
  (all binary.and
       index.as_binary
       index.as_binary
       ))

(the .public random
  (Random (Name_And_Type Any))
  (all random.and
       index.random
       index.random
       ))
