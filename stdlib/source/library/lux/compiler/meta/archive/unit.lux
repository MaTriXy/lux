(.using
 [library
  [lux (.except :module)
   [abstract
    [equality (.only Equality)]
    [hash (.only Hash)]]
   [data
    ["[0]" pair]
    ["[0]" text (.only)
     ["%" \\injection]]
    [collection
     ["[0]" set (.only Set)]]]
   [math
    [number
     [/64
      ["[0]" natural]]]]]]
 [//
  ["[0]" module]
  ["[0]" artifact]])

(every .public ID
  (Record
   [:module module.ID
    :artifact artifact.ID]))

(the .public hash
  (Hash ID)
  (all pair.hash
       natural.hash
       natural.hash
       ))

(the .public equality
  (Equality ID)
  (by ..hash equality))

(alias [=]
       ..equality)

(the .public none
  (Set ID)
  (set.empty ..hash))

(the .public (as_text it)
  (text.Injection ID)
  (text (%.natural (its :module it))
        "."
        (%.natural (its :artifact it))))
