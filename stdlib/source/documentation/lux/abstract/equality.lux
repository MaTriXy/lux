(.using
 [library
  [lux (.except)
   ["$" documentation]]]
 [\\library
  ["[0]" /]])

(the .public documentation
  (List $.Documentation)
  (list ($.module /._
                  "")

        ($.definition /.functor)

        ($.definition (/.Equality it)
          "Equality for a type's instances.")

        ($.definition /.rec
          "A recursive equality combinator."
          ($.example (' (rec recursive_equality))))))
