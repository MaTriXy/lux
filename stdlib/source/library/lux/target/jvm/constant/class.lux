(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" equality (.only Equality)]]
   [data
    [binary
     [\\injection (.only Injection)]]]
   [math
    ["[0]" random (.only Random) (.open functor)]]
   [type
    ["[0]" nominal]]]]
 [//
  [utf8 (.only UTF8)]
  [//
   ["[0]" index (.only Index)]]])

(the Reification
  (type (Index UTF8)))

(nominal.every .public Class
  ..Reification

  (the .public index
    (-> Class
        ..Reification)
    (|>> nominal.as))
  
  (the .public class
    (-> ..Reification
        Class)
    (|>> nominal.of))

  (the .public equality
    (Equality Class)
    (by equality.functor each
        ..index
        index.equality))

  (alias [=]
         ..equality)

  (the .public as_binary
    (Injection Class)
    (|>> nominal.as
         index.as_binary))
  )

(the .public random
  (Random Class)
  (|> index.random
      (is (Random ..Reification))
      (random:each class)))
