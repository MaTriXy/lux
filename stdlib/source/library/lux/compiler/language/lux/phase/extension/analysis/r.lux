(.using
 [library
  [lux (.except Analysis)
   ["[0]" ffi]
   [abstract
    ["<>" projection]]
   [data
    [collection
     ["[0]" dictionary]]]
   ["[0]" type (.only)
    ["[0]" check]]
   [target
    ["_" r]]
   ["[0]" code
    ["<[1]>" \\projection]]]]
 [//
  ["/" lux (.only custom)]
  [//
   ["[0]" bundle]
   [//
    ["[0]" analysis
     ["[1]/[0]" type]]
    [//
     ["[0]" analysis (.only Analysis Operation Phase Handler Bundle)]
     [///
      ["[0]" phase]]]]]])

(the .public bundle
  Bundle
  (<| (bundle.prefix "r")
      (|> bundle.empty
          )))
