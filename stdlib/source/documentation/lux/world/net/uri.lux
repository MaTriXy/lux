(.using
 [library
  [lux (.except)
   ["$" documentation]
   ["[0]" debug]
   [control
    ["[0]" io]]]]
 [\\library
  ["[0]" /]])

(the .public documentation
  (List $.Documentation)
  (list ($.module /._
                  "")
        
        ($.definition /.URI
          "A Uniform Resource Identifier.")
        ))
