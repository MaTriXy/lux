(.using
 [library
  [lux (.except)
   ["$" documentation]
   [meta
    [macro
     ["[0]" template]]]]]
 [\\library
  ["[0]" /]])

(`` (the .public documentation
      (List $.Documentation)
      (list ($.module /._
                      "")

            ($.definition /.co_prime?)
            ($.definition /.even?)
            ($.definition /.odd?)
            ($.definition /.real)
            ($.definition /.equality)
            ($.definition /.order)
            ($.definition /.enum)
            ($.definition /.interval)
            ($.definition /.addition)
            ($.definition /.multiplication)
            ($.definition /.minimum)
            ($.definition /.maximum)
            ($.definition /.base_02)
            ($.definition /.base_08)
            ($.definition /.base_10)
            ($.definition /.base_16)
            ($.definition /.hash)

            (,, (template.with [<name> <documentation>]
                  [($.definition <name>
                     <documentation>)]

                  [[/.= "Natural equality."]
                   [/.+ "Natural addition."]
                   [/.- "Natural substraction."]
                   [/.< "Natural less-than."]
                   [/.<= "Natural less-than or equal."]
                   [/.> "Natural greater-than."]
                   [/.>= "Natural greater-than or equal."]
                   [/.x "Natural multiplication."]
                   [/./ "Natural division."]
                   [/./% "Natural [division remainder]."]
                   [/.% "Natural remainder."]]
                  ))

            (,, (template.with [<name> <doc>]
                  [($.definition <name>
                     <doc>)]

                  [[/.minor "Natural minimum."]
                   [/.major "Natural maximum."]]
                  ))

            ($.definition /.gcd
              "Greatest Common Divisor.")

            ($.definition /.lcm
              "Least Common Multiple.")
            )))
