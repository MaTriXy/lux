(.using
 [library
  [lux (.except)
   ["$" documentation]
   [data
    [collection
     ["[0]" list]]]]]
 [\\library
  ["[0]" /]])

(the .public documentation
  (List $.Documentation)
  (list ($.module /._
                  "")

        ($.definition /.equality)
        ($.definition /.as_code)

        ($.definition /.Declaration
          "A declaration for either a constant or a function.")

        ($.definition /.of_code
          "A projection for declaration syntax."

          ($.comment "Such as:")
          ($.example (' quux))
          ($.example (' (foo bar baz))))
        ))
