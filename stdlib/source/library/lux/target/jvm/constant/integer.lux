(.using
 [library
  [lux (.except Integer)
   [data
    ["[0]" binary
     ["[1]" \\injection (.only Injection)]]]
   [math
    [random (.only Random)]
    [number
     ["i[0]" /32
      ["[1]" integer]]]]]])

(every .public Integer
  i/32.Number)

(alias [equality =]
       i/32.equality)

(the .public as_binary
  (Injection Integer)
  i/32.as_binary)

(the .public random
  (Random Integer)
  i/32.random)
