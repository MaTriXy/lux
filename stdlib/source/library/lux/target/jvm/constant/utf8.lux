(.using
 [library
  [lux (.except)
   [data
    ["[0]" text]
    ["[0]" binary
     ["[1]F" \\injection (.only Injection)]]]
   [math
    ["[0]" random (.only Random)]]]])

(every .public UTF8
  Text)

(alias [equality =]
       text.equality)

(the .public as_binary
  (Injection UTF8)
  binaryF.utf8_16)

(the .public random
  (Random UTF8)
  (random.unicode 3))
