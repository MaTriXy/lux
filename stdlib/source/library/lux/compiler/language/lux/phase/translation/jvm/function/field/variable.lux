(.using
 [library
  [lux (.except Type type)
   [data
    [collection
     ["[0]" list (.open functor)]
     ["[0]" sequence]]]
   [target
    [jvm
     ["_" bytecode (.only Bytecode)]
     ["[0]" modifier (.only Modifier) (.open monoid)]
     ["[0]" field (.only Field)]
     [type (.only Type)
      [category (.only Value Class)]]
     [constant
      [pool (.only Resource)]]]]]]
 ["[0]" ////
  ["[1][0]" type]
  ["[1][0]" reference]
  [//////
   [type (.only Register)]]])

(the .public type
  ////type.value)

(the .public (get class name)
  (-> (Type Class) Text
      (Bytecode Any))
  (all _.composite
       ////reference.this
       (_.getfield class name ..type)
       ))

(the .public (put naming class register value)
  (-> (-> Register Text) (Type Class) Register (Bytecode Any)
      (Bytecode Any))
  (all _.composite
       ////reference.this
       value
       (_.putfield class (naming register) ..type)))

(the modifier
  (Modifier Field)
  (all modifier:composite
       field.private
       field.final
       ))

(the .public (variable name type)
  (-> Text (Type Value)
      (Resource Field))
  (field.field ..modifier name false type (sequence.new)))

(the .public (variables naming amount)
  (-> (-> Register Text) Nat
      (List (Resource Field)))
  (|> amount
      list.domain
      (list:each (function (_ register)
                   (..variable (naming register) ..type)))))
