(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]
    ["[0]" projection]]
   [data
    ["[0]" maybe (.open functor)]]
   [error
    ["[0]" try]
    ["[0]" exception]]
   [math
    ["[0]" random (.only Random)]
    [number
     [/64
      ["n" natural]
      ["r" real]]]
    [geometry
     ["[0]" circle]]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" /]]
 ["[0]" \\projection])

(/.every (Shape [] _)
         [:perimeter (/.Method [] Real)
          :area (/.Method [] Real)])

(every Circle
       (Record
        [:radius Real]))

(the circle
     (Shape Circle)
     [:perimeter (/.method
                  (function (_ next again [this _])
                            (all r.x +2.0 circle.pi (its :radius (/.state this)))))
      :area (/.method
             (function (_ next again [this _])
                       (let [radius (its :radius (/.state this))]
                            (all r.x circle.pi radius radius))))])

(every Square
       (Record
        [:side Real]))

(the square
     (Shape Square)
     [:perimeter (/.method
                  (function (_ next again [this _])
                            (all r.x +4.0 (its :side (/.state this)))))
      :area (/.method
             (function (_ next again [this _])
                       (let [side (its :side (/.state this))]
                            (all r.x side side))))])

(the (scaled scalar)
     (-> Real (Shape Real)
         (Shape Real))
     (|>> (/.override :perimeter
                      (function (_ next again [this input])
                                (all r.x
                                     scalar
                                     (next [this input]))))
          (/.override :area
                      (function (_ next again [this input])
                                (all r.x
                                     scalar scalar
                                     (next [this input]))))))

(the value
     (Random Real)
     (by random.functor each
         (|>> (n.% 100) n.real)
         random.natural))

(the \\projection
     Test
     (<| (_.covering \\projection._)
         (_.for [\\projection.Projection
                 \\projection.value])
         (monad.let [! random.monad]
                    [radius ..value
                     side ..value])
         (all _.and
              (_.coverage [\\projection.any]
                          (when (\\projection.value (list (/.object ..circle [:radius radius]))
                                                    (is (\\projection.Projection Shape Real)
                                                        (monad.let projection.monad
                                                                   [it (\\projection.any ..circle)]
                                                                   (pure (/.state it)))))
                                {try.:Success actual}
                                (identical? radius actual)

                                {try.:Failure _}
                                false))
              (_.coverage [\\projection.wrong_class]
                          (when (\\projection.value (list (/.object ..square [:side side]))
                                                    (is (\\projection.Projection Shape Real)
                                                        (monad.let projection.monad
                                                                   [it (\\projection.any ..circle)]
                                                                   (pure (/.state it)))))
                                {try.:Failure error}
                                (exception.is? \\projection.wrong_class error)

                                {try.:Success _}
                                false))
              )))

(the .public test
     Test
     (<| (_.covering /._)
         (monad.let [! random.monad]
                    [radius ..value
                     side ..value
                     scale ..value])
         (_.for [/.Instance /.Object
                 /.every])
         (all _.and
              (_.coverage [/.object /.class]
                          (|> [:side side]
                              (/.object ..square)
                              (is (/.Object Shape Square))
                              /.class
                              (identical? ..square)))
              (_.coverage [/.state]
                          (and (|> [:side side]
                                   (/.object ..square)
                                   (is (/.Object Shape Square))
                                   /.state
                                   (identical? side))
                               (|> [:radius radius]
                                   (/.object ..circle)
                                   (is (/.Object Shape Circle))
                                   /.state
                                   (identical? radius))))
              (_.coverage [/.Method
                           /.:complete /.:partial
                           
                           /.method /.of]
                          (let [it (is (/.Object Shape Circle)
                                       (/.object circle [:radius radius]))]
                               (and/or (not (r.= (/.of :perimeter [] it)
                                                 (/.of :area [] it)))
                                       (comment "Corner cases"
                                                (and/or (r.= +0.0 radius)
                                                        (comment "Fun little coincidence."
                                                                 (r.= +2.0 radius)))))))
              (_.coverage [/.override]
                          (and (r.= (/.of :perimeter [] (/.object ..square [:radius (r.x scale radius)]))
                                    (/.of :perimeter [] (/.object (..scaled scale ..square) [:radius radius])))
                               (r.= (/.of :area [] (/.object ..square [:radius (r.x scale radius)]))
                                    (/.of :area [] (/.object (..scaled scale ..square) [:radius radius])))))
              (_.coverage [/.as]
                          (let [it (|> [:side side]
                                       (/.object ..square)
                                       (is (/.Object Shape Square)))]
                               (|> it
                                   (is (/.Object Shape))
                                   (/.as ..square)
                                   (is (Maybe (/.Object Shape Square)))
                                   (maybe:each (identical? it))
                                   (maybe.else false))))

              ..\\projection
              )))
