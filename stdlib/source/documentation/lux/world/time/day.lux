(.using
 [library
  [lux (.except)
   ["$" documentation]]]
 [\\library
  ["[0]" /]])

(the .public documentation
  (List $.Documentation)
  (list ($.module /._
                  "")

        ($.definition /.equality)
        ($.definition /.order)
        ($.definition /.enum)
        ($.definition /.not_a_day_of_the_week)
        ($.definition /.format)
        ($.definition /.number)
        ($.definition /.invalid_day)
        ($.definition /.by_number)
        ($.definition /.hash)

        ($.definition /.Day
          "A day of the week.")

        ($.definition /.week
          "All the days, ordered by when they come in a week.")
        ))
