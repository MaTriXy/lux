(.using
 [library
  [lux (.except i64 text)
   [macro
    ["[0]" template]]
   [target
    ["_" python (.only Expression)]]]]
 ["[0]" //
  ["[1][0]" runtime]])

(template.with [<type> <name> <implementation>]
  [(the .public <name>
     (-> <type>
         Expression)
     <implementation>)]

  [[Bit bit _.bool]
   [(I64 Any) i64 (|>> .integer _.int //runtime.i64:64)]
   [Real f64 _.float]
   [Text text _.unicode]])
