(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]]
   [data
    ["[0]" text]
    [collection
     ["[0]" set]
     ["[0]" list (.use functor)]]]
   [math
    ["[0]" random (.only Random)]
    [number
     [/64
      ["n" natural]]]]
   [macro
    ["[0]" template]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" /]])

(the .public random
  (Random /.Context)
  (monad.let [! random.monad]
    [context (all random.either
                  (pure /.js)
                  (pure /.jvm)
                  (pure /.lua)
                  (pure /.python)
                  (pure /.ruby))]
    (by ! each context (random.lower_cased 1))))

(the .public test
  Test
  (<| (_.covering /._)
      (_.for [/.Extension

              /.Context
              /.:host /.:host_module_extension /.:target /.:artifact_extension])
      (monad.let [! random.monad]
        [target (random.lower_cased 1)]
        (all _.and
             (_.coverage [/.js /.jvm /.lua /.python /.ruby /.c++]
               (let [contexts (list (/.js target)
                                    (/.jvm target)
                                    (/.lua target)
                                    (/.python target)
                                    (/.ruby target)
                                    (/.c++ target))
                     maximum (list.size contexts)]
                 (`` (and (,, (template.with [<amount> <slot>]
                                [(|> contexts
                                     (list:each (its <slot>))
                                     (set.of_list text.hash)
                                     set.size
                                     (n.= <amount>))]

                                [[maximum /.:host]
                                 [maximum /.:host_module_extension]
                                 [maximum /.:artifact_extension]
                                 [1 /.:target]]))))))
             ))))
