(.using
 [library
  [lux (.except :version)
   [abstract
    [equality (.only Equality)]]
   [data
    ["[0]" pair]
    ["[0]" text (.only)
     ["%" \\injection]]]]]
 ["[0]" /// (.only Snapshot)
  ["[1][0]" time]
  ["[1][0]" stamp]])

(every .public Value
  (Record
   [:version Text
    :snapshot Snapshot]))

(the .public equality
  (Equality Value)
  (all pair.equality
       text.equality
       ///.equality
       ))

(alias [=]
       ..equality)

(comment "https://en.wikipedia.org/wiki/Delimiter"
         (the delimiter
           "-"))

(the .public snapshot
  "SNAPSHOT")

(the .public (as_text it)
  (text.Injection Value)
  (with "/[0]" it
    (when /:snapshot
      {///.:Local}
      /:version
      
      {///.:Remote stamp}
      (with "/[0]" stamp
        (text (text.replaced ..snapshot
                             (///time.as_text /:time)
                             /:version)
              ..delimiter
              (%.natural /:build))))))
