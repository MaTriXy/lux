(.using
 [library
  [lux (.except)
   [data
    [collection
     ["[0]" list (.use functor)]]]
   [math
    [number
     [/64
      ["i" integer]
      ["r" real]]]]
   [macro
    ["[0]" template]]]]
 [//
  [rgb (.only RGB)]
  ["[0]" hsl]
  ["[0]" hsb]])

(the (ratio it)
  (Change Real)
  (if (r.> +1.0 it)
      (r.% +1.0 it)

      (r.< +0.0 it)
      (|> it (r.% +1.0) (r.+ +1.0))

      it))

(template.with [<name> <1> <2>]
  [(`` (the .public (<name> it)
         (-> RGB
             [RGB RGB RGB])
         (let [(open "/[0]") (hsl.of_rgb it)]
           [it
            (hsl.rgb (hsl.hsl (|> /:hue (r.+ <1>) ..ratio)
                              /:saturation
                              /:luminance))
            (hsl.rgb (hsl.hsl (|> /:hue (r.+ <2>) ..ratio)
                              /:saturation
                              /:luminance))])))]

  [[triad            (|> +1.0 (r./ +3.0)) (|> +2.0 (r./ +3.0))]
   [clash            (|> +1.0 (r./ +4.0)) (|> +3.0 (r./ +4.0))]
   [split_complement (|> +1.0 (r./ +5.0)) (|> +3.0 (r./ +5.0))]]
  )

(template.with [<name> <1> <2> <3>]
  [(`` (the .public (<name> it)
         (-> RGB
             [RGB RGB RGB RGB])
         (let [(open "/[0]") (hsl.of_rgb it)
               of_hue (is (-> hsl.Value
                              RGB)
                          (function (_ hue)
                            (hsl.rgb (hsl.hsl hue /:saturation /:luminance))))]
           [it
            (|> /:hue (r.+ <1>) ..ratio of_hue)
            (|> /:hue (r.+ <2>) ..ratio of_hue)
            (|> /:hue (r.+ <3>) ..ratio of_hue)])))]

  [[square   (|> +1.0 (r./ +4.0))  (|> +2.0 (r./ +4.0))  (|> +3.0 (r./ +4.0))]
   [tetradic (|> +2.0 (r./ +12.0)) (|> +6.0 (r./ +12.0)) (|> +8.0 (r./ +12.0))]]
  )

(every .public Spread
  Real)

(comment "https://en.wikipedia.org/wiki/Color_scheme"
         (every .public Scheme
           (-> Spread Natural RGB
               (List RGB))))

(the .public (analogous spread variations it)
  Scheme
  (let [it (hsl.of_rgb it)
        hue (its hsl.:hue it)
        saturation (its hsl.:saturation it)
        luminance (its hsl.:luminance it)
        spread (..ratio spread)]
    (list:each (function (_ idx)
                 (hsl.rgb (hsl.hsl (|> idx ++ .integer i.real (r.x spread) (r.+ hue) ..ratio)
                                   saturation
                                   luminance)))
               (list.domain variations))))

(the .public (monochromatic spread variations it)
  Scheme
  (let [it (hsb.of_rgb it)
        hue (hsb.hue it)
        saturation (hsb.saturation it)
        brightness (hsb.brightness it)
        spread (..ratio spread)]
    (|> (list.domain variations)
        (list:each (|>> ++ .integer i.real
                        (r.x spread)
                        (r.+ brightness)
                        ..ratio
                        (hsb.hsb hue saturation)
                        hsb.rgb)))))
