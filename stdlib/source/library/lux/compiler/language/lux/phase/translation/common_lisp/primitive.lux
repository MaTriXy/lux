(.using
 [library
  [lux (.except i64)
   [target
    ["_" common_lisp (.only Expression)]]]])

(the .public bit
  (-> Bit (Expression Any))
  _.bool)

(the .public i64
  (-> (I64 Any) (Expression Any))
  (|>> .integer
       _.int))

(the .public f64
  (-> Real (Expression Any))
  _.double)

(the .public text
  (-> Text (Expression Any))
  _.string)
