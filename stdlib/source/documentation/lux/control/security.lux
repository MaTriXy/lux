(.using
 [library
  [lux (.except)
   ["$" documentation]
   [data
    [collection
     ["[0]" list]]]]]
 ["[0]" /
  ["[1][0]" capability]
  ["[1][0]" policy]])

(the .public documentation
  (.List $.Documentation)
  (list.together
   (list /policy.documentation
         /capability.documentation)))
