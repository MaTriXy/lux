(.using
 [library
  [lux (.except)
   [macro
    ["[0]" template]]]]
 [//
  [rgb (.only RGB)]])

(every .public Alpha
  Revolution)

(template.with [<value> <name>]
  [(the .public <name>
     Alpha
     <value>)]

  [[.0 transparent]
   [.5 translucent]]
  )

(the .public opaque
  Alpha
  (-- transparent))

(every .public Pigment
  (Record
   [:color RGB
    :alpha Alpha]))
