(.using
 [library
  [lux (.except)
   [data
    ["[0]" text]
    [collection
     ["[0]" set]
     ["[0]" list]]]
   [math
    ["[0]" random (.only Random) (.use "[1]:[0]" monad)]
    [number
     [/64
      ["n" natural]]]]
   [test
    ["_" property (.only Test)]]]]
 [\\program
  ["[0]" /]])

(the .public random
  (Random /.Type)
  (all random.either
       (all random.either
            (random:pure /.lux_library)
            (random:pure /.jvm_library))
       (all random.either
            (random:pure /.pom)
            (random:pure /.md5)
            (random:pure /.sha1))
       ))

(the .public test
  Test
  (<| (_.covering /._)
      (_.for [/.Type]
             (all _.and
                  (_.coverage [/.lux_library /.jvm_library /.js_library
                               /.pom /.md5 /.sha1]
                    (let [options (list /.lux_library /.jvm_library /.js_library
                                        /.pom /.md5 /.sha1)
                          uniques (set.of_list text.hash options)]
                      (n.= (list.size options)
                           (set.size uniques))))
                  ))))
