(.using
 [library
  [lux (.except)
   [type
    ["[0]" nominal]]]]
 [//
  [signature (.only Signature)]])

(nominal.every .public (Key k)
  Signature

  (the .public signature
    (for_any (_ it)
      (-> (Key it)
          Signature))
    (|>> nominal.as))

  (the .public (key signature sample)
    (for_any (_ it)
      (-> Signature it
          (Key it)))
    (nominal.of signature))
  )
