(.using
 [library
  [lux (.except)
   ["$" documentation]]]
 [\\library
  ["[0]" /]])

(the .public documentation
  (List $.Documentation)
  (list ($.module /._
                  "")

        ($.definition /.equality)
        ($.definition /.width)
        ($.definition /.i32)
        ($.definition /.i64)

        ($.definition /.I32
          "A 32-bit integer.")
        ))
