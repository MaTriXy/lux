(.using
 [library
  [lux (.except i64 text)
   [macro
    ["[0]" template]]
   [target
    ["_" lua (.only Literal)]]]])

(template.with [<name> <type> <implementation>]
  [(the .public <name>
     (-> <type>
         Literal)
     <implementation>)]

  [[bit Bit _.boolean]
   [i64 I64 (|>> .integer _.int)]
   [f64 Decimal _.float]
   [text Text _.string]]
  )
