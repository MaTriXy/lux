(.using
 [library
  [lux (.except)
   [abstract
    [equality (.only Equality)]
    ["[0]" monad]]
   ["[0]" function]
   [math
    ["[0]" random]
    [number
     [/64
      ["n" natural]]]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" /]])

(the .public test
  Test
  (<| (_.covering /._)
      (_.in_parallel (list))))

(the .public (spec equality value it)
  (for_any (_ ! it)
    (-> (Equality (! it)) (! it) (/.Functor !)
        Test))
  (monad.let random.monad
    [sample random.natural]
    (<| (_.for [/.Functor])
        (all _.and
             (_.coverage [/.each]
               (let [law_of_identity!
                     (by equality =
                         (by it each function.identity value)
                         value)]
                 (and law_of_identity!)))
             ))))
