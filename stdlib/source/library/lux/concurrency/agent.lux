(.using
 [library
  [lux (.except)
   [control
    ["[0]" io (.only IO)]]
   [error
    ["[0]" try (.only Try)]]]]
 [//
  [future (.only Future)]
  ["[0]" actor (.only Actor)]
  ["[0]" frp (.only Channel')]])

(the .public Agent
  Actor)

(the .public (react! events handler agent)
  (for_any (_ eventR eventW state)
    (-> (Channel' eventR eventW)
        (-> eventR state (Future (Try state)))
        (Agent state)
        (IO Any)))
  (frp.subscribe! (function (_ event)
                    (actor.mail! (function (_ state self)
                                   (handler event state))
                                 agent))
                  events))
