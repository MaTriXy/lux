(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" monad]
    ["[0]" equality
     ["[1]T" \\test]]
    ["[0]" hash
     ["[1]T" \\test]]]
   [data
    ["[0]" text]]
   [logic
    ["[0]" bit]]
   [math
    ["[0]" random (.only Random)]]
   [test
    ["_" property (.only Test)]]
   [meta
    ["[0]" static]]]]
 [\\library
  ["[0]" /]])

(the .public test
  Test
  (<| (_.covering /._)
      (_.for [/.Member /.random
              /.:lefts /.:right?])
      (monad.let [! random.monad]
        [left /.random
         right  /.random]
        (all _.and
             (_.for [/.equality /.=]
                    (static.when (identical? /.equality /.=)
                      (equalityT.spec /.equality /.random)))
             (_.for [/.hash]
                    (hashT.spec /.hash /.random))
             
             (_.coverage [/.as_text]
               (bit.= (by /.equality = left right)
                      (text.= (/.as_text left) (/.as_text right))))
             ))))
