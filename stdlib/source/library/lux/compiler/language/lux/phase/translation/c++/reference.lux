(.using
 [library
  [lux (.except local)
   [control
    ["|" pipe]]
   [data
    ["[0]" product]
    [text
     ["%" \\injection]]]
   [macro
    ["[0]" template]]
   [target
    ["_" c++]]]]
 [//
  ["/" runtime (.only Operation)]
  [//
   ["[0]" reference]
   [///
    ["[0]" phase (.use monad)]
    ["[0]" translation]
    [///
     [reference
      [register (.only Register)]
      ["[0]" variable (.only Variable)]]
     [meta
      [archive (.only Archive)]]]]]])

(template.with [<prefix> <name>]
  [(the .public <name>
     (-> Register
         _.Local)
     (|>> %.nat
          (text <prefix>)
          _.local))]

  [["l" local]
   ["f" foreign]
   ["p" partial]]
  )

(the .public this
  _.Local
  (..local 0))

(the .public variable
  (-> Variable
      _.Local)
  (|>> (|.when
         {variable.:Local it}
         (..local it)
         
         {variable.:Foreign it}
         (..foreign it))))

(the .public (constant archive it)
  (-> Archive Name
      (Operation _.Address))
  (phase:each (|>> product.left
                   reference.artifact
                   _.local)
              (translation.definition archive it)))
