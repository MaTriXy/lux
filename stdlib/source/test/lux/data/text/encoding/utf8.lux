(.using
 [library
  [lux (.except)
   [abstract
    ["[0]" format
     ["[1]T" \\test]]]
   [data
    ["[0]" text]]
   [math
    ["[0]" random (.only Random)]]
   [test
    ["_" property (.only Test)]]]]
 [\\library
  ["[0]" /]])

(the .public test
  Test
  (<| (_.covering /._)
      (_.for [/.binary]
             (formatT.spec text.equality /.binary (random.unicode 5)))))
