(.using
 [library
  [lux (.except Definition :Definition)
   [abstract
    [equality (.only Equality)]]
   [data
    ["[0]" product]
    ["[0]" text]]
   [macro
    ["^" pattern]]]]
 [//
  ["[0]" definition (.only Definition)]
  [////
   [arity (.only Arity)]]])

(every .public Category
  (Variant
   {:Anonymous}
   {:Definition Definition}
   {:Custom Text}))

(the .public equality
  (Equality Category)
  (implementation
   (the (= left right)
     (when [left right]
       [{:Anonymous} {:Anonymous}]
       true

       [{:Definition left} {:Definition right}]
       (by definition.equality = left right)
       
       [{:Custom left} {:Custom right}]
       (text.= left right)

       _
       false
       ))))

(alias [=]
       ..equality)
